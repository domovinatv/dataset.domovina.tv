564
00:24:27,380 --> 00:24:28,040
 i ljudi,

565
00:24:28,040 --> 00:24:28,240
 evo,

566
00:24:28,240 --> 00:24:29,300
 osobno,

567
00:24:29,300 --> 00:24:30,660
 i preko tvog

568
00:24:30,660 --> 00:24:31,920
 volonterskog,

569
00:24:31,920 --> 00:24:33,700
 volonterska aktivnosti,

570
00:24:33,700 --> 00:24:34,840
 si je uspjela vidjeti

571
00:24:34,840 --> 00:24:35,720
 evo,

572
00:24:35,720 --> 00:24:36,240
