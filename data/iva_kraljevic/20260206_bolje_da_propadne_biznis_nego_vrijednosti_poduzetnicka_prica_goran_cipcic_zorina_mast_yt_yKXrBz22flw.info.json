 vjeri da i iz malih početaka može nastati nešto veliko.\n\nAko želite još ovakvih razgovora, podržite moj rad na poveznici: https://patreon.com/IvaKraljevic?utm_medium=unknown&utm_source=join_link&utm_campaign=creatorshare_creator&utm_content=copyLink", "channel_id": "UCT6Sx8T7walJ0dpOgqHllkw", "channel_url": "https://www.youtube.com/channel/UCT6Sx8T7walJ0dpOgqHllkw", "duration": 4516, "view_count": 15346, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=yKXrBz22flw", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1770393606, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 49, "like_count": 744, "channel": "Iva Kraljevic", "channel_follower_count": 27200, "uploader": "Iva Kraljevic", "uploader_id": "@ivakraljevic.", "uploader_url": "https://www.youtube.com/@ivakraljevic.", "upload_date": "20260206", "timestamp": 1770393606, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "yKXrBz22flw", "fulltitle": "Bolje da propadne biznis nego vrijednosti. / poduzetnička priča, Goran Čipčić, Zorina Mast", "duration_string": "1:15:16", "release_date": "20260206", "release_year": 2026, "is_live": false, "was_live": false, "epoch": 1771414381, "asr": 44100, "filesize": 206531754, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 24, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 365.857, "filesize_approx": 206531672, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr4---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=1771435981&ei=baOVaenMJJChvdIP6sWwgQw&ip=89.201.137.96&id=o-AIsFv0