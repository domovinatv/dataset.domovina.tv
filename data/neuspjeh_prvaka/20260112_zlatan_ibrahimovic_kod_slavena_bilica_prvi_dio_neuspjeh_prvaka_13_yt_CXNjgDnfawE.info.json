hprvaka\n\n💡 Sponzori serijala: Coca-Cola i Plazma\n🎬 Produkcija: Sportske igre mladih u suradnji s Telekom Srbija\n\n#neuspjehprvaka #zlatanibrahimovic #SlavenBilic #ibrahimovic #nogomet #football", "channel_id": "UCixjtLV3xaMi7Clfqm7R_UA", "channel_url": "https://www.youtube.com/channel/UCixjtLV3xaMi7Clfqm7R_UA", "duration": 3987, "view_count": 1590394, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=CXNjgDnfawE", "categories": ["Sports"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"en": [{"ext": "json3", "url": "https://www.youtube.com/api/timedtext?v=CXNjgDnfawE&ei=OrqVaYSEJPOI6dsPu--3oQ0&caps=asr&opi=112496729&xoaf=5&xowf=1&xospf=1&hl=en&ip=0.0.0.0&ipbits=0&expire=1771445418&sparams=ip%2Cipbits%2Cexpire%2Cv%2Cei%2Ccaps%2Copi%2Cxoaf&signature=5677ACCFA892233B709D3B77FAA1A7B723FA144A.0B85CC733A47D24655D4824B735E24B0EB0639F3&key=yt8&lang=en&fmt=json3", "name": "English", "impersonate": true}, {"ext": "srv1", "url": "https://www.youtube.com/api/timedtext?v=CXNjgDnfawE&ei=OrqVaYSEJPOI6dsPu--3oQ0&caps=asr&opi=112496729&xoaf=5&xowf=1&xospf=1&hl=en&ip=0.0.0.0&ipbits=0&expire=1771445418&sparams=ip%2Cipbits%2Cexpire%2Cv%2Cei%2Ccaps%2Copi%2Cxoaf&signature=5677ACCFA892233B709D3B77FAA1A7B723FA144A.0B85CC733A47D24655D4824B735E24B0EB0639F3&key=yt8&lang=en&fmt=srv1", "name": "English", "impersonate": true}, {"ext": "srv2", "url": "https://www.youtube.com/api/timedtext?v=CXNjgDnfawE&ei=OrqVaYSEJPOI6dsPu--3oQ0&caps=asr&opi=112496729&xoaf=5&xowf=1&xospf=1&hl=en&ip=0.0.0.0&ipbits=0&expire=1771445418&sparams=ip%2Cipbits%2Cexpire%2Cv%2Cei%2Ccaps%2Copi%2Cxoaf&signature=5677ACCFA892233B709D3B77FAA1A7B723FA144A.0B85CC733A47D24655D4824B735E24B0EB0639F3&key=yt8&lang=en&fmt=srv2", "name": "English", "impersonate": true}, {"ext": "srv3", "url": "https://www.youtube.com/api