, {"url": "https://i.ytimg.com/vi/cS3R_pIEyOQ/hqdefault.jpg?sqp=-oaymwEjCNACELwBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=&rs=AOn4CLBkG9WhERLjLqilAYZdlHaPDaNLBA", "height": 188, "width": 336, "preference": -7, "id": "38", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/cS3R_pIEyOQ/hqdefault.jpg?v=6330b5c2", "height": 360, "width": 480, "preference": -7, "id": "39", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/cS3R_pIEyOQ/hqdefault.webp", "preference": -6, "id": "40"}, {"url": "https://i.ytimg.com/vi/cS3R_pIEyOQ/sddefault.jpg", "preference": -5, "id": "41"}, {"url": "https://i.ytimg.com/vi_webp/cS3R_pIEyOQ/sddefault.webp", "preference": -4, "id": "42"}, {"url": "https://i.ytimg.com/vi/cS3R_pIEyOQ/hq720.jpg", "preference": -3, "id": "43"}, {"url": "https://i.ytimg.com/vi_webp/cS3R_pIEyOQ/hq720.webp", "preference": -2, "id": "44"}, {"url": "https://i.ytimg.com/vi/cS3R_pIEyOQ/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "45", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/cS3R_pIEyOQ/maxresdefault.webp", "preference": 0, "id": "46"}], "thumbnail": "https://i.ytimg.com/vi/cS3R_pIEyOQ/maxresdefault.jpg", "description": "Igor je oduvijek bio sportaš koji daje svoj maksimum na svakom treningu. Kasnije je isti pristup prenio na svoj posao koji danas naziva pozivom i živi ga jednako strastveno kao i sport. Možda je upravo ta strast prema sportu razlog zašto je još davne 2006. godine počeo stvarati koncept Mentalnog Treninga za vrijeme svog studija psihologije u SAD-u. Godinama je nastupao za Hrvatsku plivačku reprezentaciju na brojnim europskim i svjetskim prvenstvima te Olimpijskim igrama u Ateni 2004. godine. Nekoć vrhunski sportaš, a danas poduzetnik.\n\nŠto je teže, poduzetnička ili sportska karijera, postoji li talent, ili je težak rad najvažnija pretpostavka uspjeha, kako se stvara strast za nečim, i još puno zanimljivih stvari, uživajte!\n\n\nVinko Mihaljević\nhttps://www.linkedin.com/in/vinkomihaljevic/\nhttps://twitter.com/vinkomi\n\nLOOD\nhttps://www.lood.net/\nhttps://www.youtube.com/c/loodyt\nhttps://open.spotify.com/show/5vZr1MvvzwVho2rWkdp9Er\nhttps://www.instagram.com/lood.ig/\nhttps://www.linkedin.com/company/loodli\nhttps://www.facebook.com/lood.fb/\n\n\nhttps://www.igorcerensek.com/\nhttps://www.mentalnitrening.hr/", "channel_id": "UCWSfCCG1ai1Jenlo95WfWgw", "channel_url": "https://www.youtube.com/channel/UCWSfCCG1ai1Jenlo95WfWgw", "duration": 6219, "view_count": 6239, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=cS3R_pIEyOQ", "categories": ["Education"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1610889048, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 5, "like_count": 110, "channel": "LOOD", "channel_follower_count": 94700, "uploader": "LOOD", "uploader_id": "@lood", "uploader_url": "https://www.youtube.com/@lood", "upload_date": "20210117", "timestamp": 1610889048, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "cS3R_pIEyOQ", "fulltitle": "Igor Čerenšek: Mentalni trening", "duration_string": "1:43:39", "release_date": "20210117", "release_year": 2021, "is_live": false, "was_live": false, "epoch": 1771509097, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 104318549, "tbr": 134.191, "width": 640, "height": 360, "resolution": "640x360", "fps": 24, "dynamic_range": "SDR", "vcodec": "vp9", "vbr": 24.097, "aspect_ratio": 1.78, "acodec": "opus", "abr": 110.094, "asr": 48000, "audio_channels": 2, "_type": "video", "_version": {"version": "2026.02.04", "release_git_head": "c677d866d41eb4075b0a5e0c9