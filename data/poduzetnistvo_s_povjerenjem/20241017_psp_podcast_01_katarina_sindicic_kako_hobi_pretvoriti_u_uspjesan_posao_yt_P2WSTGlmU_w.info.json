on": "246x138"}, {"url": "https://i.ytimg.com/vi/P2WSTGlmU_w/hqdefault.jpg?sqp=-oaymwEcCNACELwBSFXyq4qpAw4IARUAAIhCGAFwAcABBg==&rs=AOn4CLAop-KfAi3W9O_9pv1wk9jUNOmAEw", "height": 188, "width": 336, "preference": -7, "id": "33", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/P2WSTGlmU_w/hqdefault.jpg", "height": 360, "width": 480, "preference": -7, "id": "34", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/P2WSTGlmU_w/hqdefault.webp", "preference": -6, "id": "35"}, {"url": "https://i.ytimg.com/vi/P2WSTGlmU_w/sddefault.jpg", "height": 480, "width": 640, "preference": -5, "id": "36", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi_webp/P2WSTGlmU_w/sddefault.webp", "preference": -4, "id": "37"}, {"url": "https://i.ytimg.com/vi/P2WSTGlmU_w/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/P2WSTGlmU_w/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/P2WSTGlmU_w/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "40", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/P2WSTGlmU_w/maxresdefault.webp", "preference": 0, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/P2WSTGlmU_w/maxresdefault.jpg", "description": "U prvoj epizodi podcasta “Poduzetništvo s povjerenjem” moderatorica Ljubica Perinić Staničić je ugostila Katarinu Sindičić, vlasnicu obrta Button World za vezene katoličke motive. Bilo je razgovora o tome kako izgleda kada supruga i majka dvoje djece, uz svoj stalni posao odgojiteljice u vrtiću, odluči pokrenuti dodatni posao. Koliko je važna podrška supruga u poduzetništvu te je li Katarina u svom poslu izrade rukotvorina strpljiva ili možda perfekcionist. Kroz svoje iskreno svjedočanstvo Katarina će nam otkriti za koje talente živi te kako je ona kroz rečeno “da” Gospodinu svoj usputni hobi pretvorila u uspješan posao. \n\nPodcast “Poduzetništvo s povjerenjem” u formi iskrenog razgovora sa ženama i muškarcima - uspješnim poduzetnicima ima za cilj podržati i potaknuti razvoj poslovanja u Hrvatskoj koji se temelji na vjeri i pouzdanju u Boga. Naši će gosti biti poduzetnici koji su tek u početcima pokretanja ili razvoja poslovanja kao i iskusni lideri s desetljećima poslovnog iskustva. Podcast će kroz poslovne, obiteljske i životne priče gostiju pokazati žive primjere načina na koji katolička vjera susreće poslovanje, a poduzeća rastu s Bogom. \n\nModeratorica: Ljubica Pernić Staničić, https://www.instagram.com/ljubica_sanantoniokomunikacije/\nGošća: Katarina Sindičić, https://www.instagram.com/button_world_/\nStudio: Film Factory: https://www.instagram.com/film_factory_zagreb/\nPjesma: Vjerujem, © Vanessa Mioč, https://www.instagram.com/vanessamioc/", "channel_id": "UCC80pbKKM2sYEqws_N41yjg", "channel_url": "https://www.youtube.com/channel/UCC80pbKKM2sYEqws_N41yjg", "duration": 2096, "view_count": 1173, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=P2WSTGlmU_w", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 4, "like_count": 50, "channel": "Poduzetništvo s povjerenjem", "channel_follower_count": 626, "uploader": "Poduzetništvo s povjerenjem", "uploader_id": "@poduzetnistvospovjerenjem", "uploader_url": "https://www.youtube.com/@poduzetnistvospovjerenjem", "upload_date": "20241017", "timestamp": 1729141217, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "P2WSTGlmU_w", "fulltitle": "PSP PODCAST 01: Katarina Sindičić - Kako hobi pretvoriti u uspješan posao?", "duration_string": "34:56", "is_live": false, "was_live": false, "epoch": 1771426873, "asr": 44100, "format_id": "18", "format_note": "360p", "source_preference"