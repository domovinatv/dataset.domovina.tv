ault.webp", "height": 480, "width": 640, "preference": -4, "id": "37", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi/T1wueq0HP2M/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/T1wueq0HP2M/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/T1wueq0HP2M/maxresdefault.jpg", "height": 720, "width": 1280, "preference": -1, "id": "40", "resolution": "1280x720"}, {"url": "https://i.ytimg.com/vi_webp/T1wueq0HP2M/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "41", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/T1wueq0HP2M/maxresdefault.webp", "description": "Kako izgleda život kada se brak, vjera, talent i poduzetništvo spoje u jedno?\nŠto se događa kada uspjeh s televizijske pozornice postane početak dubljeg osobnog i\nduhovnog puta?\n\nU ovoj epizodi PSP Podcasta donosimo iskren i inspirativan razgovor s bračnim parom Monikom i Leonom Žilavi, javnosti poznatima pod umjetničkim imenom Magic Leon.\n\nMonika i Leon otvoreno govore o svom obraćenju, bračnom zajedništvu, izazovima zajedničkog\nrada te o tome kako svoje talente – iluziju, umjetnost i kreativnost – koriste ne samo u poslovne\nsvrhe, već i za evangelizaciju na društvenim mrežama.\n\nU razgovoru otkrivamo:\n– kako su doživjeli nagli javni uspjeh i što je došlo nakon njega\n– kako izgleda rad i život u bračnoj i poslovnoj zajednici\n– na koji način vjera oblikuje njihove odluke i smjer djelovanja\n– kako koristiti talente odgovorno, autentično i s jasnom svrhom\n\nMonika Žilavi, uz ulogu asistentice i poduzetnice, govori i o svom radu kao slikarica sakralne\numjetnosti te o povezanosti umjetnosti, duhovnosti i identiteta.\n\nAko vas zanimaju priče koje spajaju vjeru, brak, kreativnost i poduzetništvo – ova epizoda\ndonosi vrijedne uvide i poticaj za osobni rast.\n\nPretplatite se na kanal PSP Podcast i pogledajte više epizoda.\n\nBeauty partner epizode:\nVeliko hvala Frizerskom salonu Ruža La Verna što brine o frizuri naše voditeljice Ljubice.\n- Frizerski salon Ruža La Verna\n- Adresa: Kašinska cesta 6, Sesvete\n- Telefon: 091 720 4966\n- Instagram: @ruza_la_verna", "channel_id": "UCC80pbKKM2sYEqws_N41yjg", "channel_url": "https://www.youtube.com/channel/UCC80pbKKM2sYEqws_N41yjg", "duration": 6392, "view_count": 762, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=T1wueq0HP2M", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 33, "channel": "Poduzetništvo s povjerenjem", "channel_follower_count": 626, "uploader": "Poduzetništvo s povjerenjem", "uploader_id": "@poduzetnistvospovjerenjem", "uploader_url": "https://www.youtube.com/@poduzetnistvospovjerenjem", "upload_date": "20251212", "timestamp": 1765537183, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "T1wueq0HP2M", "fulltitle": "PSP PODCAST E08: Leon Magic i Monika \"Kad iluzija postane svjedočanstvo\"", "duration_string": "1:46:32", "is_live": false, "was_live": false, "epoch": 1771420532, "asr": 44100, "filesize": 247614780, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 25, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 309.882, "filesize_approx": 247614155, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr3---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=1771442132&ei=dLuVaf6OCJCFp-oP2PyAqAc&ip=89.201.137.96&id=o-AKFMmeFLxaJQDCY3TBcRoYdpR-AikanLDsXC-V5zb--L&itag=18&source=youtube&requiressl=yes&xpc=EgVo2aDSNQ%3D%3D&cps=408&met=1771420532%2C&mh=6U&mm=31%2C29&mn=sn-v2uph5