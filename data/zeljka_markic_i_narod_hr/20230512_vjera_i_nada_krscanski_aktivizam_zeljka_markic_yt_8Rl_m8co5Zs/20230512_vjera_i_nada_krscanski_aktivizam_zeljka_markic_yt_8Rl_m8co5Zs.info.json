m/vi/8Rl_m8co5Zs/maxresdefault.jpg", "description": "Varazdinska Biskupija je povodom 100. godišnjice enciklike pape Pija XI. \"Ubi arcano Dei\" koja je potaknula Katoličku akciju organizirala ciklus okruglih stolova. U emisiji \"Vjera i nada\" o kršćanskom aktivizmu svemu govorila je Željka Markić, dr. med., izvršna direktorica udruge \"U ime obitelji\". Iako je dosad ugostila preko 100 gostiju u svom podcastu '55 minuta kod Željke Markić', ova emisija je sjajna jer se može čuti njeno mišljenje i ima prigodu ispričati ono s čime se susretala kroz godine aktivističkog djelovanja.\n\nEmisiju uredio i vodio Branimir Gubić.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 1500, "view_count": 3300, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=8Rl_m8co5Zs", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 14, "like_count": 143, "channel": "Željka Markić & Narod", "channel_follower_count": 8030, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20230512", "timestamp": 1683890518, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "8Rl_m8co5Zs", "fulltitle": "VJERA I NADA Kršćanski aktivizam - Željka Markić", "duration_string": "25:00", "is_live": false, "was_live": false, "epoch": 1779968620, "format": "134 - 640x360 (360p)+251 - audio only (medium)", "format_id": "134+251", "ext": "mkv", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 92386510, "tbr": 492.713, "width": 640, "height": 3