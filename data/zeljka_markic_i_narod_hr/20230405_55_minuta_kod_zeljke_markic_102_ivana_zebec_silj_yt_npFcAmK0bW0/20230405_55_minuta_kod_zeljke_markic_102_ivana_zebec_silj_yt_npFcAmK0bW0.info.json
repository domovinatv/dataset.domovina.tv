pFcAmK0bW0/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "46", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/npFcAmK0bW0/maxresdefault.webp", "description": "Dr. sc. Ivana Žebec Šilj rođena je 1977. u Osijeku. Završila je studij kroatologije i filozofije. Doktorat iz humanističkih znanosti, znanstveno polje povijest, stekla je 2011. u Zagrebu. Zaposlena je u Institutu društvenih znanosti Ivo Pilar gdje je radila na nizu projekata. Njena znanstvena postignuća je nemoguće navesti u kratkom opisu ovog videa. Od 2015. vanjska je suradnica Leksikografskog zavoda Miroslav Krleža na izdanjima Hrvatske tehničke enciklopedije, Enciklopedije Hrvatskog zagorja i Turopoljskog leksikona. Predavala je na diplomskom studiju povijesti na Hrvatskim studijima. Do sada je objavila 18 znanstvenih članaka u raznim inozemnim i hrvatskim znanstvenim časopisima i publikacijama. Također, objavila je jednu autorsku znanstvenu knjigu, uredila šest zbornika znanstvenih radova i jednu znanstvenu knjigu na engleskom jeziku kod uglednog izdavača u SAD-u. Udana je i majka je jedne kćeri.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3209, "view_count": 1369, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=npFcAmK0bW0", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1680726724, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 1, "like_count": 48, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20230405", "timestamp": 1680726724, "availability": "public"