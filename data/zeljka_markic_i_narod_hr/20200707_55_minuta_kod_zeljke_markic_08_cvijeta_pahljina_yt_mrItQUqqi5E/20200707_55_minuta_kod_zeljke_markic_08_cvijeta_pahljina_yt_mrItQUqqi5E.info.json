erapiju. U Hrvatskoj i Sloveniji vodi postdiplomsku nastavu i edukacije iz logoterapije. Utemeljitelj ove treće bečke psihoterapijske škole je prof. Viktor Frankl, Židov koji je preživio nacističke logore. Logoterapija ili egzistencijalna analiza pomaže širokom rasponu ljudi - od onih sa raznih psihičkim smetnjama poput fobija, depresije, ovisnosti do zdravih ljudi u krizi ili traženju smisla u svom životu.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3179, "view_count": 6427, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=mrItQUqqi5E", "categories": ["People & Blogs"], "tags": ["logoterapija", "cvijeta pahljina", "logopedagogija", "psihijatar", "psihologija", "željka markić", "55 minuta", "viktor frankl"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1594144812, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 13, "like_count": 208, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20200707", "timestamp": 1594144812, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "mrItQUqqi5E", "fulltitle": "55 minuta kod Željke Markić #08 - Cvijeta Pahljina", "duration_string": "52:59", "release_date": "20200707", "release_year": 2020, "is_live": false, "was_live": false, "epoch": 1772713585, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 132437310, "tbr": 333.308, "width": 640, "height": 360,