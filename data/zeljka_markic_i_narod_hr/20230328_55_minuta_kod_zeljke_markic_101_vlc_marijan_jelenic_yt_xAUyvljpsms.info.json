ijan Jelenić je nedavno umirovljen vodnjanski župnik. U zasluženu mirovinu otišao je nakon čak 5 desetljeća službe. Uz svećeničke i župničke dužnosti, ostavio je neizbrisiv trag u očuvanju sakralne i kulturne baštine grada Vodnjana, a osobito brojnih relikvija. Objavio je čak 40 knjiga, a kao krunu svog literarnog rada, uspio je prikupiti građu i urediti ‘najotmjeniju knjigu tiskanu u Hrvatskoj' - sveobuhvatnu monografiju vodnjanskog relikvijskog blaga.\n\n\n#Vodnjan #istra #relic", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3420, "view_count": 3165, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=xAUyvljpsms", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1680030907, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 12, "like_count": 125, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20230328", "timestamp": 1680030907, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "xAUyvljpsms", "fulltitle": "55 minuta kod Željke Markić #101 - vlč. Marijan Jelenić", "duration_string": "57:00", "release_date": "20230328", "release_year": 2023, "is_live": false, "was_live": false, "epoch": 1772706739, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 126037276, "tbr": 294.85699999999997, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, 