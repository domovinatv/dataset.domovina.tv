, napuhanim cijenama vode i konkretnim prometnim rješenjima koja bi učinile Zagreb boljim mjestom za Život. \nSlaven Dobrović je rođen je u Zadru, diplomirao je na Fakultetu strojarstva i brodogradnje Sveučilišta u Zagrebu, na procesno-energetskom smjeru. Magistrirao je 1998. godine. Doktorirao je 2002. godine. Glavna područja znanstvenog interesa uključuju područje voda i zaštita okoliša, posebno razvoj i primjena ekološki zasnovanih sustava gospodarenja otpadom. Oženjen je suprugom Agnezom s kojom ima sedmero djece.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3069, "view_count": 3265, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=rlIcNNvkCcc", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1620762296, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=rlIcNNvkCcc&bpctr=9999999999&has_verified=1", "video_id": "rlIcNNvkCcc", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 23, "like_count": 176, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210511", "timestamp": 1620762296, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "rlIcNNvkCcc", "fulltitle": "55 minuta kod Željke Markić #42 - Slaven Dobrović", "duration_string": "51:09", "release_date": "20210511", "release_year": 2021, "is_live": false, "was_live": false, "epoch": 1772710904, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "fo