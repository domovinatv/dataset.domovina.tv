ku na mjesto pročelnika dan prije primopredaje vlasti te je automatizmom ostao na funkciji savjetnika Tomislava Tomaševića. Govorio je o čemu savjetuje gradonačelnika, zašto tvrdi da je ukidanje mjere roditelj odgojitelj protivno Statutu Zagreba, zakonu i Ustavu te koliko bi milijuna europskog novca Zagreb mogao izgubiti zbog \"nečinjenja\".", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3434, "view_count": 2860, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=52Y2hw1mHkI", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1641928558, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=52Y2hw1mHkI&bpctr=9999999999&has_verified=1", "video_id": "52Y2hw1mHkI", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 5, "like_count": 91, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20220111", "timestamp": 1641928558, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "52Y2hw1mHkI", "fulltitle": "55 minuta kod Željke Markić #72 - Ivica Lovrić", "duration_string": "57:14", "release_date": "20220111", "release_year": 2022, "is_live": false, "was_live": false, "epoch": 1772708662, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 124626815, "tbr": 290.304, "width": 640, "height": 360, "resolution": "64