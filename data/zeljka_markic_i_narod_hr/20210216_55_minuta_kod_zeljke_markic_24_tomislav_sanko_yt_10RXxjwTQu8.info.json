ojne obveze prijavljuje se u postulaturu Franjevačke provincije svetog Jeronima sa sjedištem u Zadru. Postulaturu i novicijat završava na otočiću Košljunu te odlazi na studij teologije u Asiz. Po završetku studija vraća se u domovinu te je imenovan župnim vikarom u Župi Presvetog Srca Isusova na Voštarnici u Zadru. Nakon četiri godine službe imenovan je tajnikom i odgojiteljem postulanata te animatorom za duhovna zvanja. Službu vrši u matičnom Samostanu sv. Frane u Zadru. Nakon četiri godine imenovan je župnikom Župe sv. Nikole Tavelića u Rijeci gdje se trenutno nalazi.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3649, "view_count": 7884, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=10RXxjwTQu8", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 23, "like_count": 331, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210216", "timestamp": 1613502000, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "10RXxjwTQu8", "fulltitle": "55 minuta kod Željke Markić #24 - Tomislav Šanko", "duration_string": "1:00:49", "is_live": false, "was_live": false, "epoch": 1772712224, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 127116383, "tbr": 278.71000000000004, "width": 640, "height": 360, "resolution": "640x360", "fps": 2