.ytimg.com/vi_webp/6or6nZ1vmH4/maxresdefault.webp", "preference": 0, "id": "46"}], "thumbnail": "https://i.ytimg.com/vi/6or6nZ1vmH4/maxresdefault.jpg", "description": "Pater Mislav Skelin rođen je u Zagrebu 1978. godine, a u Družbu Isusovu stupio je godine 2005. U podcastu 55 minuta kod Željke Markić govori kako je tekao put od dječaka sa Bukovačke ceste do svećeničkog poziva, na koji način se približio Bogu i kako je vođen načelima Ignacijeve duhovnosti. \nPater Skelin studirao je teologiju na Papinskom sveučilištu Gregoriana, a godine 2011. primio je đakonsko i svećeničko ređenje. Četiri godine bio je na službi u Osijeku kao svećenik u kapelici Presvetog Srca Isusova i vjeroučitelj u Isusovačkoj klasičnoj gimnaziji, te kao duhovnik zajednice Taize. Od 2015. studira školsku pedagogiju na Papinskom sveučilištu Salesiana u Rimu.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3497, "view_count": 3494, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=6or6nZ1vmH4", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1622747089, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 9, "like_count": 160, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210603", "timestamp": 1622747089, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "6or6nZ1vmH4", "fulltitle": "55 minuta kod Željke Markić #48 - Mislav Skelin", "duration_string": "58:17", "release_date": "20210603", "release_year