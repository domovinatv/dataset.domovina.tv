"}, {"url": "https://i.ytimg.com/vi_webp/5lsvVZyIDIg/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "46", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/5lsvVZyIDIg/maxresdefault.webp", "description": "Prof. dr. sc. Nenad Pokos rođen je 1965. godine u Zagrebu. Diplomirao je 1991. godine na Geografskom odsjeku PMF-a Sveučilišta u Zagrebu. Kao znanstveni savjetnik radi u Institutu društvenih znanosti Ivo Pilar. Posebno se bavi istraživanjima povezanim s demografijom Hrvatske, regionalnom demografijom i promjenama u strukturama stanovništva. Redoviti je profesor na Hrvatskim studijima Sveučilišta u Zagrebu gdje je nositelj kolegija Politička geografija na Odsjeku komunikologije i kolegija Stanovništvo svijeta na Odsjeku sociologije. Na Hrvatskom katoličkom sveučilištu nositelj je kolegija Politička geografija i Demografska obilježja svijeta na Odjelu za sociologiju. Objavio je 60-ak znanstvenih i stručnih radova u međunarodno referiranim časopisima, zbornicima radova i knjigama. Sudjelovao je na pedesetak hrvatskih i međunarodnih znanstvenih skupova. Trenutno je član Radne skupine za izradu Nacrta prijedloga Strategije demografske revitalizacije Republike Hrvatske do 2031. godine. Nositelj je Spomenice Domovinskog rata 1990.-1992.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3666, "view_count": 1272, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=5lsvVZyIDIg", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1666166409, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 3, "like_count": 57, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "upl