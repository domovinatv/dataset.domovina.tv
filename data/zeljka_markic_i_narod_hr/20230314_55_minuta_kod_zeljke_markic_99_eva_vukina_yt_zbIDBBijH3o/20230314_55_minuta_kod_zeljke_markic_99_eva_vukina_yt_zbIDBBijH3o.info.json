pg", "description": "Eva Vukina je umjetnica čiji crteži i slike oduševljavaju. Široj javnosti postala je poznata slikom djevojčice u plavom kaputiću iz Vukovara te ilustracijama vukovarske Golgote, potresa i drugih događaja koji izazivaju trpljenje velikog broja ljudi. Ali, i slikama Modrića, blaženika i svetaca. Eva je rođena u Čakovcu 1993. godine. Diplomirala je na odsjeku slikarstva na Akademiji primijenjenih umjetnosti Sveučilišta u Rijeci. Kroz akademsko obrazovanje okušala se u području slikarstva, kiparstva, grafike i fotografije. Često se bavi sakralnim motivima i izradom personaliziranih ilustracija duhovne tematike.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3485, "view_count": 3698, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=zbIDBBijH3o", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1678824909, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 13, "like_count": 155, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20230314", "timestamp": 1678824909, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "zbIDBBijH3o", "fulltitle": "55 minuta kod Željke Markić #99 - Eva Vukina", "duration_string": "58:05", "release_date": "20230314", "release_year": 2023, "is_live": false, "was_live": false, "epoch": 1772706847, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note"