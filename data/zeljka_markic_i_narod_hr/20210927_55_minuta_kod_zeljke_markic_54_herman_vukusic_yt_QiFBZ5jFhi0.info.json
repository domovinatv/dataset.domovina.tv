"}, {"url": "https://i.ytimg.com/vi_webp/QiFBZ5jFhi0/maxresdefault.webp", "preference": 0, "id": "46"}], "thumbnail": "https://i.ytimg.com/vi/QiFBZ5jFhi0/maxresdefault.jpg", "description": "Herman Vukušić govori o tragediji na Mlinovima, emocionalnom zlostavljanju, otuđivanju djece, gdje počinje struka i gdje prestaju jeftini poeni političara, salonskih kvaziliberala i pseudoaktivista. Diplomirao i završio poslijediplomski studij na Medicinskom fakultetu u Zagrebu. Objavio je veći broj stručnih i znanstvenih radova iz područja medicine stresa i menadžmenta, te je čest predavač na skupovima u zemlji i inozemstvu. Član je međunarodne Akademije za menadžment, američke Akademije eksperata za traumatski stres i stručni je konzultant Europske komisije. Predsjednik je Hrvatskog društva za medicinu stresa i Centra za duhovnu medicinu. Obnašao je i dužnost pomoćnika ministrice obitelji, branitelja i međugeneracijske solidarnosti u vladi RH.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3423, "view_count": 4432, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=QiFBZ5jFhi0", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1632771344, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=QiFBZ5jFhi0&bpctr=9999999999&has_verified=1", "video_id": "QiFBZ5jFhi0", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 19, "like_count": 198, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210927", "timestamp": 1632771344, "availability": "pub