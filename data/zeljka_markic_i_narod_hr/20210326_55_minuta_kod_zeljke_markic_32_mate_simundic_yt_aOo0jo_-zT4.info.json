 kod Željke Markić. Rođen je 1973. u Splitu, gdje završava MIOC, nakon čega studira kroatistiku, komparativnu književnost i teologiju u Zagrebu. Nekoliko godina je živio u Meksiku kao misionar u družbi Majke Tereze iz Kolkate. Radi kao profesor u I. gimnaziji u Splitu, prevodio je s engleskog i španjolskog i bio urednik za nakladnu kuću Verbum. Živi u Kaštel Lukšiću sa suprugom i petoro djece. Govori o kandidaturi za župana, smislu županija i problemima s kojima se susreću, iskustvima u Meksiku i stvaranju perspektive za mlade u njegovoj županiji.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3506, "view_count": 2479, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=aOo0jo_-zT4", "categories": ["People & Blogs"], "tags": ["mate šimunić", "kaštel lukšić"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 11, "like_count": 121, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210326", "timestamp": 1616789371, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "aOo0jo_-zT4", "fulltitle": "55 minuta kod Željke Markić #32 - Mate Šimundić", "duration_string": "58:26", "is_live": false, "was_live": false, "epoch": 1772711673, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 138241007, "tbr": 315.397, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dy