 "Dr. sc. Slaven Dobrović, nositelj je liste br. 11 Domovinskog pokreta u 7. izbornoj jedinici. Otkrio nam je kako se kao student prijavio u vojsku i Božić 1991. dočekao na Velebitu, u kojem društvu najviše voli navijati za hrvatsku reprezentaciju, kako izgleda svakodnevica obitelji sa 7 djece. Ovaj profesor na Strojarskom fakultetu objasnio je kako svako domaćinstvo u Hrvatskoj može proizvoditi svoju struju,  koje će promijene unijeti u HEP i zašto danas svoju ženu voli više nego kad su se vjenčali.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3356, "view_count": 4175, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=hXznIZwlGYU", "categories": ["People & Blogs"], "tags": ["55 min", "55 minuta", "55", "66", "44", "45", "60", "minuta", "kod", "sa", "željke markić", "željkom markić", "željka markić", "žELJKA", "MARKIĆ", "PREDIZBORNA EMISIJA", "U IME OBITELJI", "NAROD.HR", "OSOBNO", "HRVATSKA", "IZBORI", "2020", "STRANKA", "DOMOVINA", "SLAVEN", "DOBROVIĆ", "DOMOVINSKI POKRET", "MOST", "POLITIKA", "CROATIA", "VIJESTI"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1593691212, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=hXznIZwlGYU&bpctr=9999999999&has_verified=1", "video_id": "hXznIZwlGYU", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 31, "like_count": 166, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20200702", "timestamp": 1593691212, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "you