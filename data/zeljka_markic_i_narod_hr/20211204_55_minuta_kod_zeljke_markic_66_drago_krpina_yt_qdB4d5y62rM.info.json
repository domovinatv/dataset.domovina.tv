https://i.ytimg.com/vi/qdB4d5y62rM/hq720.jpg", "preference": -3, "id": "43"}, {"url": "https://i.ytimg.com/vi_webp/qdB4d5y62rM/hq720.webp", "preference": -2, "id": "44"}, {"url": "https://i.ytimg.com/vi/qdB4d5y62rM/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "45", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/qdB4d5y62rM/maxresdefault.webp", "preference": 0, "id": "46"}], "thumbnail": "https://i.ytimg.com/vi/qdB4d5y62rM/maxresdefault.jpg", "description": "Drago Krpina hrvatski je političar i pjesnik. Rođen je u Radošinovcu 1960. godine. Osnovnu školu polazio je i završio je u Radošinovcu i Stankovcima. Srednju školu polazio je i završio u Puli i Zadru. Hrvatski jezik i književnost studirao je na Filozofskom fakultetu u Zadru, a potom na Učiteljskom fakultetu u Gospiću i Zagrebu gdje je i diplomirao. Jedan je od osnivača Hrvatske demokratske zajednice. Na početku balvan-revolucije, u srpnju 1990. godine, imenovan je predsjednikom Kriznog štaba za sjevernu i srednju Dalmaciju. Uskoro dobiva čin brigadira Hrvatske vojske, te postaje načelnikom Političke uprave Ministarstva obrane. Jedno vrijeme bio je savjetnikom za okupirana područja i predstojnikom Ureda za mirnu reintegraciju predsjednika Republike dra Franje Tuđmana.\nU Hrvatskom saboru bio je zastupnik u prva četiri saziva (1990. – 2003.), a od 3. prosinca 1998. godine glavni tajnik Hrvatske demokratske zajednice do 6. ožujka 2000. godine kada je podnio ostavku.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3777, "view_count": 8048, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=qdB4d5y62rM", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1638611838, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "a