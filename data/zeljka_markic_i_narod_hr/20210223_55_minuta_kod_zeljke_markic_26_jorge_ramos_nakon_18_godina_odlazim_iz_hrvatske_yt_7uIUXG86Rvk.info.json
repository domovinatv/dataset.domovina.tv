, rodnom Portu, pravnoj organizaciji Opusa Dei, odnosu Ivana Pavla II prema sv. Josemariji Escrivi. Protumačio je zašto je ispovijedanje jedna od karizmi Opusa Dei, kakvu formaciju je prešlo preko 2,000 svećenika Djela Božjeg koji danas djeluju u 68 država svijeta. Objasnio je i kako vidi odnos neokatekumenskog puta i Opusa Dei, kako je učio i naučio hrvatski i zašto je u Hrvatskoj bio jako sretan.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3110, "view_count": 10235, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=7uIUXG86Rvk", "categories": ["People & Blogs"], "tags": ["jorge ramos", "don ramos", "željka markić", "opus dei", "jorge ramos opus dei", "ramos opus dei"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 54, "like_count": 298, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210223", "timestamp": 1614116895, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "7uIUXG86Rvk", "fulltitle": "55 minuta kod Željke Markić #26 - Jorge Ramos | Nakon 18 godina odlazim iz Hrvatske", "duration_string": "51:50", "is_live": false, "was_live": false, "epoch": 1772712087, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 113630821, "tbr": 292.303, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dynamic_range": "SDR", "vcodec": "vp9", "vbr": 157.