fault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "45", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/lD31tw7To3k/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "46", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/lD31tw7To3k/maxresdefault.webp", "description": "Tomislav Kršnjavi, poznati hrvatski akademski kipar, autor brojnih kipova koji kraše crkve, trgove i javne prostore diljem Lijepe naše, prapraunuk Izidora Kršnjavog, hrvatskog slikara, povjesničara umjetnosti, kulturnog djelatnika  - gost je emisije 55 minuta kod Željke Markić. U emisiji je govorio o svom kiparskom pozivu, načinu nastanka kiparskih djela, o “Čipkarici” s Paga, “Beraču soli”, kipu blaženog kardinala Kuharića, Stepinca, Tinu Ujeviću i sv. Petru u Makarskoj, o trgu koji je osmislio ispred crkve u Zmijavcima te crkvenim vratima na koja je osobito ponosan… Ispričao je kako je upoznao svoju suprugu Lindu s kojom ima četvero djece, također darovitu kiparicu te objasnio kako je to kad dva kipara žive zajedno pod istim krovom…", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3725, "view_count": 2084, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=lD31tw7To3k", "categories": ["People & Blogs"], "tags": ["tomislav kršnjavi", "linda kršnjavi", "zmijavci", "crkva zmijavci", "alojzije stepinac", "franjo kuharić"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1615316453, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=lD31tw7To3k&bpctr=9999999999&has_verified=1", "video_id": "lD31tw7To3k", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 6, "like_count": 122, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210309", "timestamp": 1615316453, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "lD31tw7To3k", "fulltitle": "55 minuta kod Željke Markić #29 - Tomislav Kršnjavi", "duration_string": "1:02:05", "release_date": "20210309", "release_year": 2021, "is_live": false, "was_live": false, "epoch": 1772711862, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 122494914, "tbr": 263.055, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dynamic_range": "SDR", "vcodec": "vp9", "vbr": 135.758, "aspect_ratio": 1.78, "acodec": "opus", "abr": 127.297, "asr": 48000, "audio_channels": 2, "_type": "video", "_version": {"version": "2026.03.03", "release_git_head": "2ecc4c3bc300701d85e2cbaeb2b28a921a68f0f0", "repository": "yt-dlp/yt-dlp"}}