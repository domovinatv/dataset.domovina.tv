hq720.webp", "preference": -2, "id": "44"}, {"url": "https://i.ytimg.com/vi/e6P8nEF_g7s/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "45", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/e6P8nEF_g7s/maxresdefault.webp", "preference": 0, "id": "46"}], "thumbnail": "https://i.ytimg.com/vi/e6P8nEF_g7s/maxresdefault.jpg", "description": "Fra Mario Knezović rođen je 1973. u Posušju kao deveto dijete u obitelji Ljube i Zore r. Sjemenište s klasičnom gimnazijom od 1989. do 1993. pohađao je u Dubrovniku, Visokome i Sinju. U Franjevački red stupio je 1993. na Humcu. Fakultetsko obrazovanje, diplomsko i poslijediplomsko pohađao je na Sveučilištima u Zagrebu i Mostaru. Osim teologije i filozofije uže znanstveno područje studiranja mu je novinarstvo, političke znanosti i komunikologija. Doktorsku disertaciju je obranio 2018. s titulom doktora znanosti iz područja informacijsko-komunikacijskih znanosti i odnosa s javnošću. Ravnateljem Informativnoga centra Mir Međugorje i glavnim urednikom Radijske postaje Mir Međugorje postaje 2001. godine.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3821, "view_count": 25304, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=e6P8nEF_g7s", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1643404035, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=e6P8nEF_g7s&bpctr=9999999999&has_verified=1", "video_id": "e6P8nEF_g7s", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 114, "like_count": 873, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkama