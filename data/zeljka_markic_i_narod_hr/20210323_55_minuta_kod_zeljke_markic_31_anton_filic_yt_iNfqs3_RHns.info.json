Večernjeg lista  2011. godine gost je emisije 55 minuta kod Željke Markić. U emisiji je povodom 10. obljetnice spomenutog štrajka, Anton Filić se prisjetio glavnih razloga za štraj Večernjakovaca, korupcije u hrvatskom pravosuđu na koju su tada ukazivali, privatizacijske krađe koju su odradili HDZ i SDP vezano za Večernji te o ulozi „patera Tolja“ u prodaji VL austrijskoj Styriji. Filić je 8 godina bio predsjednik Hrvatskog sindikata novinara  - podsjetio je na netransparentnu vlasničku strukturu mnogih medija u Hrvatskoj i težak položaj svih onih novinara koji pošteno i odgovorno rade svoj posao.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3344, "view_count": 1318, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=iNfqs3_RHns", "categories": ["People & Blogs"], "tags": ["antun filić"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 2, "like_count": 54, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210323", "timestamp": 1616529141, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "iNfqs3_RHns", "fulltitle": "55 minuta kod Željke Markić #31 - Anton Filić", "duration_string": "55:44", "is_live": false, "was_live": false, "epoch": 1772711736, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 130141582, "tbr": 311.334, "width": 640, "height": 360, "resolutio