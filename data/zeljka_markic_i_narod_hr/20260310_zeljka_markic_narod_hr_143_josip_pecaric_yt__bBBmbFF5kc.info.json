8, "width": 336, "preference": -7, "id": "37", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/_bBBmbFF5kc/hqdefault.jpg?sqp=-oaymwEjCNACELwBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=&rs=AOn4CLAmOR-TA55MHqKXwGgmHmxp5C0hhQ", "height": 188, "width": 336, "preference": -7, "id": "38", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/_bBBmbFF5kc/hqdefault.jpg?v=69b03828", "height": 360, "width": 480, "preference": -7, "id": "39", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/_bBBmbFF5kc/hqdefault.webp", "preference": -6, "id": "40"}, {"url": "https://i.ytimg.com/vi/_bBBmbFF5kc/sddefault.jpg", "preference": -5, "id": "41"}, {"url": "https://i.ytimg.com/vi_webp/_bBBmbFF5kc/sddefault.webp", "preference": -4, "id": "42"}, {"url": "https://i.ytimg.com/vi/_bBBmbFF5kc/hq720.jpg", "preference": -3, "id": "43"}, {"url": "https://i.ytimg.com/vi_webp/_bBBmbFF5kc/hq720.webp", "preference": -2, "id": "44"}, {"url": "https://i.ytimg.com/vi/_bBBmbFF5kc/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "45", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/_bBBmbFF5kc/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "46", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/_bBBmbFF5kc/maxresdefault.webp", "description": "Josip Pečarić hrvatski je matematičar, publicist i akademik HAZU.\nRođen je u Kotoru 1948. godine. U rodnome gradu polazio je i završio osnovnu i srednju školu. Diplomirao je 1972. na Elektrotehničkom fakultetu u Beogradu s radom iz područja nuklearne fizike, a magistrirao je na istome fakultetu 1975. godine. Doktorirao je 1982. godine matematičke znanosti disertacijom \"Jensenove i povezane nejednakosti\". Nakon studija radio je u Geomagnetskom institutu u Grocki, te na Građevinskom fakultetu u Beogradu, do 1987. godine, a iste godine s obitelji odlazi u Zagreb gdje se je zaposlio na Tekstilno-tehnološkom fakultetu Sveučilišta u Zagrebu. Od 2019 radi na moskovskom RUDN sveučilištu. Osim što je redoviti član HAZU, aktivni je član The New York Academy of Science. Jedan je od vodećih svjetskih stručnjaka u području teorije nejednakosti\nNajplodniji je hrvatski znanstvenik s više od 1.000 znanstvenih radova iz područja matematike te više od 100 publicističkih knjiga, u kojima se bavi temama ključnim za razumijevanje stvaranja hrvatske države.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3693, "view_count": 3205, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=_bBBmbFF5kc", "categories": ["People & Blogs"], "tags": ["josip pečarić", "akademik pečarić"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1773169206, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=_bBBmbFF5kc&bpctr=9999999999&has_verified=1", "video_id": "_bBBmbFF5kc", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 43, "like_count": 384, "channel": "Željka Markić & Narod", "channel_follower_count": 7640, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20260310", "timestamp": 1773169206, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "_bBBmbFF5kc", "fulltitle": "Željka Markić & Narod.hr #143 - Josip Pečarić", "duration_string": "1:01:33", "release_date": "20260310", "release_year": 2026, "is_live": false, "was_live": false, "epoch": 1773294324, "asr": 22050, "filesize": 128006726, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 25, "audio_channels": 2, "height": 360, "quali