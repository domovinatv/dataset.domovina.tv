g", "preference": -3, "id": "43"}, {"url": "https://i.ytimg.com/vi_webp/b7_4eSpK_Bg/hq720.webp", "preference": -2, "id": "44"}, {"url": "https://i.ytimg.com/vi/b7_4eSpK_Bg/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "45", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/b7_4eSpK_Bg/maxresdefault.webp", "preference": 0, "id": "46"}], "thumbnail": "https://i.ytimg.com/vi/b7_4eSpK_Bg/maxresdefault.jpg", "description": "Josipa Nemet je rođena u Zagrebu, doktorica znanosti iz područja biokemije i molekularne biologije i viša asistentica na Institutu Ruđer Bošković. Ova nekad profesionalna košarkašica analizirala je \"zdravstveni odgoj\" koji se ove godine provodi u svim osnovnim školama u Rijeci i dokazala da je znanstveno neutemeljen, a za djecu štetan. Ona i suprug roditelji su 4 kćeri i 1 sina. Upravo je majčinstvo produbilo njezin interes za pitanja razvoja djeteta, odrastanja i zaštite djetinjstva, što ju je potaknulo i na društveni angažman u tom području. Predsjednica je udruge Članak 64 \nkoja se zalaže za prava roditelja i djece te za odgovoran pristup pitanjima odgoja, obrazovanja i javnih politika koje se tiču djetinjstva.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 4147, "view_count": 807, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=b7_4eSpK_Bg", "categories": ["People & Blogs"], "tags": ["josipa nemet", "članak64", "članak 64", "clanak 64"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1773774006, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 9, "like_count": 132, "channel": "Željka Markić & Narod", "channel_follower_count": 7700, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "htt