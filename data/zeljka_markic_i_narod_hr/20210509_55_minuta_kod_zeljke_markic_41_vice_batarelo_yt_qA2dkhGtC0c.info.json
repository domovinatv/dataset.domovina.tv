m/vi/qA2dkhGtC0c/maxresdefault.jpg", "description": "Vincent John \"Vice\" Batarelo hrvatski je sociolog i aktivist, predsjednik katoličke udruge Vigilare.  Rodio se u obitelji hrvatskih iseljenika u Sydneyu u Australiji 1969. godine. Diplomirao je na sveučilištu Macquarie u Sydneyu. Preselio se u Hrvatsku 1990. godine. U podcastu 55 minuta kod Željke Markić govori o životu u Australiji, kako je bilo biti Hrvat dok formalno nije bilo Hrvatske, zašto se odlučio na povratak u Hrvatsku. Objasnio je zašto je Hrvatska zemlja puna prilika, što je temeljna pristojnost u civilnom diskursu i netoleranciji ljevice i o iskrivljenoj medijskoj slici po pitanju brojnih tema koje tište naše društvo.", "channel_id": "UCUxKo1ZDaHyXQwr3_w4FZgw", "channel_url": "https://www.youtube.com/channel/UCUxKo1ZDaHyXQwr3_w4FZgw", "duration": 3466, "view_count": 5385, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=qA2dkhGtC0c", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1620589572, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=qA2dkhGtC0c&bpctr=9999999999&has_verified=1", "video_id": "qA2dkhGtC0c", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 31, "like_count": 233, "channel": "Željka Markić & Narod", "channel_follower_count": 7590, "uploader": "Željka Markić & Narod", "uploader_id": "@zeljkamarkicinarod", "uploader_url": "https://www.youtube.com/@zeljkamarkicinarod", "upload_date": "20210509", "timestamp": 1620589572, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "qA2dkhGtC0c", "fulltitle": "55 minuta kod Željke Markić #41 - Vice Batarelo", "duration_string": "57:46", "re