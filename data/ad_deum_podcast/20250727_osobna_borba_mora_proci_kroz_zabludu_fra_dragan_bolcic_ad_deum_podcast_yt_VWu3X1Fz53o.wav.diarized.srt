[SPEAKER_01] i ja,

2316
01:16:35,279 --> 01:16:35,800
[SPEAKER_01] kažem,

2317
01:16:35,800 --> 01:16:37,699
[SPEAKER_01] smatram da imamo još više,

2318
01:16:37,699 --> 01:16:38,079
[SPEAKER_01] naravno,

2319
01:16:38,079 --> 01:16:38,720
[SPEAKER_01] prostora,

2320
01:16:38,720 --> 01:16:39,739
[SPEAKER_01] ovaj,

2321
01:16:39,739 --> 01:16:40,699
[SPEAKER_01] u evangelizaciji,

2322
01:16:40,699 --> 01:16:41,699
[SPEAKER_01] definitivno,

2323
01:16:41,699 --> 01:16:42,659
[SPEAKER_01] s tim,

2324
01:16:42,659 --> 01:16:43,880
[SPEAKER_01] da možda danas,

2325
01:16:43,880 --> 01:16:44,560
[SPEAKER_01] s druge strane,

2326
01:16:44,560 --> 01:16:45,319
[SPEAKER_01] treba biti,

2327
01:16:45,319 --> 01:16:45,479
[SPEAKER_01] evo,

2328
01:16:45,479 --> 01:16:47,039
[SPEAKER_01] negdje malo i pažljiv,

2329
01:16:47,039 --> 01:16:48,119
[SPEAKER_01] evo,

2330
