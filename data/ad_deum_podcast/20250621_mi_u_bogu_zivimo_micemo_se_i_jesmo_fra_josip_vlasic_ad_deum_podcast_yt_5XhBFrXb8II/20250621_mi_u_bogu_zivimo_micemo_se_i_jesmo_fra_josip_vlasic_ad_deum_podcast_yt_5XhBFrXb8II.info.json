ite ih na: https://modrastijena.com/\n\n\nTIMESTAMPS\n00:00:00 Uvod\n00:02:32 O Masnoj Luci\n00:10:00 Što je molitva?\n00:17:11 Temelji molitve\n00:18:55 Molitva kao istinski odnos s Bogom\n00:22:40 Osobna i zajednička molitva\n00:27:30 Kako osluškivati?\n00:35:25 Naljepše molitve\n00:43:55 O usmenoj molitvi\n00:50:00 Koraci za kvalitetno razmatranje\n00:58:06 Sveta Misa i časoslov\n01:02:36 O pokretanju e-duhovnih vježbi\n01:06:55 O digitalnoj evangelizaciji\n01:08:58 O sadržaju u aplikaciji\n01:15:32 O Franjevačkom svjetovnom redu\n01:28:36 O molitvenim zajednicama\n01:33:45 Poruka\n01:34:40 Završne riječi i odjava\n\n\nPRATITE NAS\nInstagram: https://instagram.com/ad.deum.podcast\nFacebook: https://www.facebook.com/AdDeumPodcast\nTikTok: https://www.tiktok.com/@ad.deum.podcast\nE-mail: addeumpodcast@gmail.com\n\n\nSva prava zadržana.\nAd Deum - Prema Bogu\n\n#AdDeumPodcast #FraJosipVlašić #Vjera #Crkva #Molitva #Planina #Podcast", "channel_id": "UCnekAGEPTcDzgkRiODg6sJA", "channel_url": "https://www.youtube.com/channel/UCnekAGEPTcDzgkRiODg6sJA", "duration": 5755, "view_count": 77563, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=5XhBFrXb8II", "categories": ["People & Blogs"], "tags": ["Ad Deum Podcast", "Fra Josip Vlašić", "katolički podcast", "molitva", "duhovnost", "vjera", "crkva", "planina", "Masna Luka", "Blidinje", "Široki Brijeg", "Isus Krist", "Bog", "fratar", "ljubav", "trećari", "Franjevački svjetovni red", "e-duhovne vježbe", "vjera mladih", "sv. Franjo", "Gospa", "srce", "svjedočanstvo", "mladi", "razmatranje"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1750527006, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=5XhBFrXb8II&bpctr=9999999999&has_verified=1", "video_id": "5XhBFrXb8II", "ext": "json", "protocol": "yout