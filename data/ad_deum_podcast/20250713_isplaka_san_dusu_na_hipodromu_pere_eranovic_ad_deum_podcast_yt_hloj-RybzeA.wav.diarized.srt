1093
01:01:29,900 --> 01:01:30,380
[SPEAKER_03] od, od,

1094
01:01:30,380 --> 01:01:30,920
[SPEAKER_03] ljud,

1095
01:01:30,920 --> 01:01:31,219
[SPEAKER_03] možda,

1096
01:01:31,320 --> 01:01:32,360
[SPEAKER_03] ajme,

1097
01:01:32,360 --> 01:01:32,940
[SPEAKER_03] nek mi neko objasni,

1098
01:01:32,940 --> 01:01:33,739
