ytimg.com/vi_webp/Xz6a_k9szRA/sddefault.webp", "height": 480, "width": 640, "preference": -4, "id": "37", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi/Xz6a_k9szRA/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/Xz6a_k9szRA/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/Xz6a_k9szRA/maxresdefault.jpg", "height": 720, "width": 1280, "preference": -1, "id": "40", "resolution": "1280x720"}, {"url": "https://i.ytimg.com/vi_webp/Xz6a_k9szRA/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "41", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/Xz6a_k9szRA/maxresdefault.webp", "description": "Iran je posljednjih dana u središtu svjetske pozornosti. Dok jedni zazivaju vojnu intervenciju i rušenje režima, drugi upozoravaju da se radi o suverenoj državi u čija se unutarnja pitanja ne bi smjelo miješati.\n\nU ovoj emisiji otvaramo ključno pitanje: ima li međunarodna zajednica pravo – i ako da, kada – intervenirati u unutarnje političke odnose suverenih država? Može li se vlast u Iranu promijeniti mirnim putem u sustavu u kojem građani ne mogu mijenjati Ustav niti slobodno birati političke predstavnike, ili je promjena moguća isključivo revolucijom?\n\nRaspravljamo o prirodi aktualnih nemira u Iranu – jesu li riječ o prosvjedima ili pokušaju revolucije – te o moralnim i pravnim granicama oružanog otpora. Imaju li druge države pravo pomagati prosvjednike i gdje završava solidarnost, a počinje destabilizacija?\n\nAnaliziramo i različite globalne pristupe: kinesku politiku nemiješanja nasuprot američkom intervencionizmu, procjene stvarne podrške iranskoj vlasti, ulogu zapadnih medija, ali i pitanje bi li eventualni američki napad uopće mogao dovesti do promjene režima – ili bi proizveo još radikalniji ishod.\n\nPosebnu pažnju posvećujemo mladim generacijama u Iranu, kulturnom i vrijednosnom jazu, ulozi žena u društvu, nuklearnom programu te pokušajima Zapada da kao alternativu nametne povratak dinastije Pahlavi.\n\nNa kraju, postavljamo ključno pitanje: bi li vojna intervencija donijela slobodu – ili samo novu tragediju?\n\nHvala vam na pažnji i povjerenju. Vidimo se uskoro s novim analizama političkih i ekonomskih događaja od svjetskog značaja.\n\n#iran #sad #politika #vijesti", "channel_id": "UCrOF0wrN-xV2j-4x85cR0lg", "channel_url": "https://www.youtube.com/channel/UCrOF0wrN-xV2j-4x85cR0lg", "duration": 2532, "view_count": 31413, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=Xz6a_k9szRA", "categories": ["News & Politics"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 255, "like_count": 1056, "channel": "Mislav Kolakušić", "channel_follower_count": 59500, "uploader": "Mislav Kolakušić", "uploader_id": "@mislavkolakusichr", "uploader_url": "https://www.youtube.com/@mislavkolakusichr", "upload_date": "20260115", "timestamp": 1768498209, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "Xz6a_k9szRA", "fulltitle": "TRUMP će pokušati eliminirati Ajatolaha Hameneija? Može li se  izvana srušiti vlast u Iranu", "duration_string": "42:12", "is_live": false, "was_live": false, "epoch": 1771421852, "asr": 44100, "filesize": 110172408, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 24, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 348.157, "filesize_approx": 110172324, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr4---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=1771443452&ei=nMCVaf_8K_O9zPsPg5XIuAk&ip=89.201.137.96&id=o-AMSR