 sustvarateljske uloge čovjeka današnjem čovjeku zvuče tako „strano“ i „zaostalo“? I zašto je demografska kriza najviše pogodila baš razvijeni Zapad – „kršćansku“ Europu i Sjevernu Amerika? Kako mijenjati mentalitet u kojemu se na djecu više gleda kao na „trošak“ kojega valja podnijeti, negoli kao na blagoslov kojega treba sa zahvalnošću primiti. Ima li nade da se u Hrvatskoj po pitanju demografskim mjera stvori nadstranački i nadideološki konsenzus? Gost: prof. dr. sc. Stjepan Baloban, pročelnik Centra za promicanje socijalnog nauka Crkve HBK.", "channel_id": "UCdeWIIyVKdg9Nq3CK5amFYA", "channel_url": "https://www.youtube.com/channel/UCdeWIIyVKdg9Nq3CK5amFYA", "duration": 2957, "view_count": 815, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=4K-iAYE7rHc", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 3, "like_count": 17, "channel": "Bitnonet", "channel_follower_count": 10100, "uploader": "Bitnonet", "uploader_id": "@Bitnonet", "uploader_url": "https://www.youtube.com/@Bitnonet", "upload_date": "20220308", "timestamp": 1646729022, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "4K-iAYE7rHc", "fulltitle": "Podcast Bitno.net-a - vlč. Baloban: Samodostatnost modernog čovjeka vodi u demografski krah", "duration_string": "49:17", "is_live": false, "was_live": false, "epoch": 1772724726, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 103604870, "tbr": 280.269, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dynamic_range": "SDR", "vcodec": "vp9", 