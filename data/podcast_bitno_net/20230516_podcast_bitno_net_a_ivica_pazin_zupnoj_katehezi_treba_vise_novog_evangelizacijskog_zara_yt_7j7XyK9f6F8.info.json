atelji će moći čuti i je li vjeronauk ispunio očekivanja Crkve, djece i roditelja ili je ''naštetio'' župskoj katehezi. Emisija je pokušala odgovoriti i na pitanje zašto se i trideset godina nakon povratka vjeronauka u hrvatski odgojno-obrazovni sustav uvijek iznova traži njegovo ukidanje i povratak ''u crkve''. Voditelj i urednik emisije je Anto Mikić.", "channel_id": "UCdeWIIyVKdg9Nq3CK5amFYA", "channel_url": "https://www.youtube.com/channel/UCdeWIIyVKdg9Nq3CK5amFYA", "duration": 2952, "view_count": 1606, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=7j7XyK9f6F8", "categories": ["Education"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 17, "channel": "Bitnonet", "channel_follower_count": 10100, "uploader": "Bitnonet", "uploader_id": "@Bitnonet", "uploader_url": "https://www.youtube.com/@Bitnonet", "upload_date": "20230516", "timestamp": 1684232290, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "7j7XyK9f6F8", "fulltitle": "Podcast Bitno.net-a - Ivica Pažin: Župnoj katehezi treba više novog evangelizacijskog žara", "duration_string": "49:12", "is_live": false, "was_live": false, "epoch": 1772724310, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 94812083, "tbr": 256.976, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dynamic_range": "SDR", "vcodec": "vp9", "vbr": 147.001, "aspect_ratio": 1.78, "acodec": "opus", "abr": 109.975, "asr": 48000, "audio_channels": 2, "_type": "video", "_version": {"version": "2026.03.03", "release_git_head": "2ecc4c3bc300701d85e2cbaeb2b28a921a68f