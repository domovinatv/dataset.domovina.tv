_webp/u0V6WnbaFwI/maxresdefault.webp", "preference": 0, "id": "47"}], "thumbnail": "https://i.ytimg.com/vi/u0V6WnbaFwI/maxresdefault.jpg", "description": "Uoči blagdana bl. Alojzija Stepinca razgovaramo o „povijesnim kontroverzama“ koje se vežu uz djelovanje Katoličke crkve i kardinala Stepinca uoči i za vrijeme Drugog svjetskog rata. Gdje su izvori i uzroci tih kontroverzi? Je li Crkva podupirala ustaški režim, a nadbiskup Stepinac „šutio“ o njegovim zločinima? Je li danas, 30 godina od pada komunizma i više od 60 godina od njegove smrti, historiografija o Alojziju Stepincu i njegovoj ulozi progovorila „mirno i objektivno“, kako je to on sam svojedobno najavljivao?\n\nO tim i drugim pitanjima s povjesničarom dr. sc. Mario Jarebom s Hrvatskog instituta za povijest, članom Mješovitog povjerenstva HBK i SPC  o Alojziju Stepincu, u novom nastavku Bitno.net-ova podcasta razgovara urednik i voditelj Anto Mikić.", "channel_id": "UCdeWIIyVKdg9Nq3CK5amFYA", "channel_url": "https://www.youtube.com/channel/UCdeWIIyVKdg9Nq3CK5amFYA", "duration": 3109, "view_count": 4567, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=u0V6WnbaFwI", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 2, "like_count": 67, "channel": "Bitnonet", "channel_follower_count": 10100, "uploader": "Bitnonet", "uploader_id": "@Bitnonet", "uploader_url": "https://www.youtube.com/@Bitnonet", "upload_date": "20210209", "timestamp": 1612854007, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "u0V6WnbaFwI", "fulltitle": "Podcast Bitno.net-a: 'Povijesne kontroverze' vezane uz kardinala Stepinca", "duration_string": "51:49", "is_live": fal