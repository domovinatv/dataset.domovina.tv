u društvu, tako i u nekim crkvenim raspravama. Jesu li žene u Crkvi „potlačene“, „drugotne“, pa bi slijedom toga Crkva bila „mizogina“ organizacija? Ili na uloge i službe u Crkvi ipak treba primjenjivati neke druge, „nesvjetovne“ kriterije kako bi ih se ispravno razumjelo?\n\nO tim i drugim pitanjima vezanima uz temu žena u Crkvi voditelj emisije Anto Mikić razgovara s dr. sc. Silvijom Migles, izvanrednom profesoricom na Katedri socijalnog nauka Crkve Katoličkog bogoslovnog fakulteta Sveučilišta u Zagrebu.", "channel_id": "UCdeWIIyVKdg9Nq3CK5amFYA", "channel_url": "https://www.youtube.com/channel/UCdeWIIyVKdg9Nq3CK5amFYA", "duration": 2895, "view_count": 966, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=IFMa-Nmv9Bw", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 2, "like_count": 16, "channel": "Bitnonet", "channel_follower_count": 10100, "uploader": "Bitnonet", "uploader_id": "@Bitnonet", "uploader_url": "https://www.youtube.com/@Bitnonet", "upload_date": "20210309", "timestamp": 1615275094, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "IFMa-Nmv9Bw", "fulltitle": "Podcast Bitno.net-a: Prisutnost i uloga žena u Crkvi", "duration_string": "48:15", "is_live": false, "was_live": false, "epoch": 1772725221, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 128884110, "tbr": 356.153, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dynamic_range": "SDR", "vcodec": "vp9", "vbr": 242.231, "aspect_ratio": 1.78, "acodec": "opus", "abr": 113.922, "asr":