", "preference": 0, "id": "47"}], "thumbnail": "https://i.ytimg.com/vi/AQ9maFcrQGA/maxresdefault.jpg", "description": "Što danas znači biti katolički vjeroučitelj? Zašto se dio društva tako uporno protivi vjeronauku u školi? Zašto, unatoč postojanju vjeronauka u školi, u Hrvatskoj i dalje ima tako puno površnog poznavanja i življenja vjere? Koji su to plodovi vidljivi 30 godina nakon povratka vjeronauka u hrvatski školski sustav? Kojim se to načelima naš gost, kao aktivni vjernik laik, vodi u svom dugogodišnjem vjeroučiteljskom, publicističkom, ali i roditeljskom djelovanju?\n\nTeme su to o kojima u novom nastavku Bitno.net podcasta njegov urednik i voditelj Anto Mikić razgovara s vjeroučiteljem i plodim katoličkim autorom Nikolom Kuzmičićem.", "channel_id": "UCdeWIIyVKdg9Nq3CK5amFYA", "channel_url": "https://www.youtube.com/channel/UCdeWIIyVKdg9Nq3CK5amFYA", "duration": 3024, "view_count": 1798, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=AQ9maFcrQGA", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 2, "like_count": 46, "channel": "Bitnonet", "channel_follower_count": 10100, "uploader": "Bitnonet", "uploader_id": "@Bitnonet", "uploader_url": "https://www.youtube.com/@Bitnonet", "upload_date": "20211130", "timestamp": 1638260970, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "AQ9maFcrQGA", "fulltitle": "Podcast Bitno.net-a - Nikola Kuzmičić: Mladi su željni vjere, ali neće da im se prenosi kroz fraze", "duration_string": "50:24", "is_live": false, "was_live": false, "epoch": 1772724889, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm",