-1, "id": "44", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/hTEh8vaYFYw/maxresdefault.webp", "preference": 0, "id": "45"}], "thumbnail": "https://i.ytimg.com/vi/hTEh8vaYFYw/maxresdefault.jpg", "description": "#budiFRAjer #antunovskihodmladih #duhovnoduhoviteveceri\n\nHrvatski katolički radio \nDuhovno duhovite večeri\nVoditelj: fra Stjepan Brčina\nGost: Tanja Kuprešak\nTema: Opraštanje; Predavanje je, pred brojnom publikom održala dr.sc.Tanja Kuprešak magistrica psihologije i psihoterapeut. Odrasla je u malom gradiću kraj Save u susjedstvu punom vesele djece. Najmlađa je od troje djece. Voli je škola a i ona školu kako sama za sebe kaže te dodaje kako voli učiti i ne zna je li ona odabrala svoje zanimanje ili ono nju. Na duhovno duhovitim večerima govorila je o temi praštanja te kako se nositi sa posljedicama svega toga. Inače, Tanja Kuorešak je ovo ljeto bila na kampu mladih na Cresu gdje je nesebično darivala svoje vrijeme i znanje kako bi mladima kojima je pomoć najviše i potrebna pomogla u važnim životnim odlukama kroz razne edukacije, predavanja i savjete, kao i razgovore kroz cijeli tjedan. Vedra i uvijek spremna pomoći ova magistrica psihologije i psihoterapeut oduševit će vas svojim predavanjem.", "channel_id": "UCzGUbyv4QoACDY7EF_fcVEA", "channel_url": "https://www.youtube.com/channel/UCzGUbyv4QoACDY7EF_fcVEA", "duration": 1787, "view_count": 14397, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=hTEh8vaYFYw", "categories": ["People & Blogs"], "tags": ["budiFRAjer", "mladi", "svetiduh", "slavljenje Boga", "klanjanje", "slavljenje", "Klanjanje pred Presvetim Oltarskim Sakramentom", "sv Antun", "Duhovno Duhovite Večeri", "DDV", "Isus", "Bog", "Duh Sveti", "fratar", "svećeništvo", "duhovni poziv", "katolici", "rimokatolici", "kršćanstvo", "poziv", "agape"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "