kdOTMHIqtUs/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/kdOTMHIqtUs/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/kdOTMHIqtUs/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "40", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/kdOTMHIqtUs/maxresdefault.webp", "preference": 0, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/kdOTMHIqtUs/maxresdefault.jpg", "description": "Kako djetetu dati slobodu, a ne izgubiti granice | Odgovornost se uči uz roditelje\n\n#roditeljstvo #odgoj #djeca \n\nU goste nam je stigla Jelena Jaranović Šalja – mama, autorica profila Tako nekako i knjige Odrastanje s prljavim koljenima.\n\nS Jelenom razgovaramo o roditeljstvu kao najodgovornijem poslu bez škole – o tome zašto nije dovoljno oslanjati se samo na intuiciju, kako izbjeći najčešće “dobre, ali pogrešne” namjere, i zašto su prljava koljena simbol zdravog i sretnog djetinjstva.  \n\nU razgovoru, između ostalog, poslušajte:\n- zašto roditeljstvo nije samo “prirodno”\n- što zapravo znači odrastanje s prljavim koljenima\n- kako kroz male izbore učimo dijete odgovornosti\n- kako postavljati granice\n- odnos partnera i baka/djedova u roditeljstvu\n- kako nas djeca mogu naučiti da budemo bolji ljudi\n\nJelena otvoreno dijeli svoja iskustva, sumnje i lekcije koje je naučila na vlastitom putu – između intuicije, struke i zdravog razuma.\n\nPretplatite se na naš kanal, lajkajte i podijelite ako vam se tema svidjela\n\n00:00 Gledat ćete...\n01:40 Uvodne riječi\n04:10 Tako nekako\n08:40 Dobra strana društvenih mreža\n11:40 Intuicija i svjesnost\n12:40 Intuicija i stručni savjeti\n17:10 Preporuka pedijatrice s kojom se ne slažem\n19:10 Roditeljstvo je prirodno, ili?\n20:20 Kako nas ugodnost vodi u probleme?\n24:40 Uvođenje dohrane kroz komade\n31:10 Zdrav razum, svjesnost i  odgovornost – uz prljava koljena\n39:00 Granice se objašnjavaju\n48:10 O zdravoj hrani\n52:10 Slušaj svoje tijelo\n57:10 Izbori vode do samostalnosti\n1:01:00 Jesu li autići za djevojčice i kućanski poslovi za dječake?\n1:05:40 Roditeljstvo je upgrade\n1:11:10 Dođi da te baba poljubi\n1:16:40 Prilika da postanemo bolji\n1:19:30 Država nam prerano oduzima djecu\n1:22:40 Ne radite po inerciji", "channel_id": "UCxr8UcEaNug50ZNVSubs-Lg", "channel_url": "https://www.youtube.com/channel/UCxr8UcEaNug50ZNVSubs-Lg", "duration": 5117, "view_count": 5272, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=kdOTMHIqtUs", "categories": ["Education"], "tags": ["#roditeljstvo", "#svjesnoroditeljstvo", "#odgoj", "#djeca", "#jelenajaranovićšalja", "#takoNekako", "#odrastanjesprljavimkoljenima", "#podcast", "#rastucisdjecom", "#bljesakpodcast", "#mame", "#tate", "#odrastanje", "#emocionalniodgoj", "#granice", "#intuicija", "#zdravrazum", "#savjeti", "#psihologija", "#obitelj", "#bakadjed", "#partnerskiodnos", "#svjesnost", "#motivacija", "#samorazvoj", "#zdravodjetinjstvo", "#igre", "#prljavakoljena", "#sretnaobitelj", "#maminzivot", "#tatainja", "#odgojsdjecu", "#razgovor", "#iskustva", "#djecjeigre", "#savjetizaroditelje", "#emocionalnarazvijenost"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 8, "chapters": [{"start_time": 0.0, "title": "Gledat ćete...", "end_time": 100.0}, {"start_time": 100.0, "title": "Uvodne riječi", "end_time": 250.0}, {"start_time": 250.0, "title": "Tako nekako", "end_time": 520.0}, {"start_time": 520.0, "title": "Dobra strana društvenih mreža", "end_time": 700.0}, {"start_time": 700.0, "title": "Intuicija i svjesnost", "end_time": 760.0}, {"start_time": 760.0, "title": "Intuicija i stručni savjeti", "end_time": 1030.0}, {"start_time": 1030.0, "title": "Preporuka pedijatrice s kojom se ne slažem", "end_time": 1150.0}, {"start_time": 1150.0, "title":