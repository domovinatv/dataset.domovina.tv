E8CMQBEG5IWvKriqkDLwgBFQAAAAAYASUAAMhCPQCAokN4AfABAfgB_gmAAtAFigIMCAAQARhVIFsoZTAP&rs=AOn4CLBFnbwAdC6yr5gO8hRzCO5E3l0blQ", "height": 110, "width": 196, "preference": -7, "id": "34", "resolution": "196x110"}, {"url": "https://i.ytimg.com/vi/DMgeFRtqpkA/hqdefault.jpg?sqp=-oaymwE9CPYBEIoBSFryq4qpAy8IARUAAAAAGAElAADIQj0AgKJDeAHwAQH4Af4JgALQBYoCDAgAEAEYVSBbKGUwDw==&rs=AOn4CLB3s8ji6a29QQZ641P-gVe6eqkcsQ", "height": 138, "width": 246, "preference": -7, "id": "35", "resolution": "246x138"}, {"url": "https://i.ytimg.com/vi/DMgeFRtqpkA/hqdefault.jpg?sqp=-oaymwE9CNACELwBSFryq4qpAy8IARUAAAAAGAElAADIQj0AgKJDeAHwAQH4Af4JgALQBYoCDAgAEAEYVSBbKGUwDw==&rs=AOn4CLAC7eAJ76RXeBGSuuxEsn_k3ysohw", "height": 188, "width": 336, "preference": -7, "id": "36", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/DMgeFRtqpkA/hqdefault.jpg?sqp=-oaymwEmCOADEOgC8quKqQMa8AEB-AH-CYAC0AWKAgwIABABGFUgWyhlMA8=&rs=AOn4CLBoOtHdBD8Jn8oqWOn6UATjFJanTQ", "height": 360, "width": 480, "preference": -7, "id": "37", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/DMgeFRtqpkA/hqdefault.webp", "preference": -6, "id": "38"}], "thumbnail": "https://i.ytimg.com/vi/DMgeFRtqpkA/hqdefault.jpg?sqp=-oaymwEmCOADEOgC8quKqQMa8AEB-AH-CYAC0AWKAgwIABABGFUgWyhlMA8=&rs=AOn4CLBoOtHdBD8Jn8oqWOn6UATjFJanTQ", "description": "U najnovijem Intervjuu tjedna gostuje Vedran Vukman, CEO Revuta. Revuto je prvi regionalni projekt lansiran na Cardanovom blockchainu, a cilj mu je postati globalni lider na sekundarnom tržištu pretplate. Ako ste uzeli godišnju pretplatu za teretanu ili Netflix i odlučili odustati nakon dva mjeseca, vaš novac ne mora biti izgubljen jer tu uskače Revuto i omogućava vam da svoju pretplatu preprodate.\n\nDodatno, Revuto vam nudi NFT s doživotnom pretplatom na Netflix i Spotify kojim možete trgovati baš kao i sa svakim drugim NFT-om. O projektu koji je i dalje u ranoj fazi, o njegovom tokenu REVU-u koji je izlistan na KuCoinu i Gate.io-u, kao i o planovima i očekivanjima u idućem bull runu, govori prvi čovjek Revuta, koji samouvjereno tvrdi da REVU može dospjeti u društvo 50 vodećih kriptovaluta!", "channel_id": "UCcQ4HZUBV_xpk1PbtQ_2ngw", "channel_url": "https://www.youtube.com/channel/UCcQ4HZUBV_xpk1PbtQ_2ngw", "duration": 2903, "view_count": 676, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=DMgeFRtqpkA", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 8, "like_count": 43, "channel": "Cryptoverse", "channel_follower_count": 12600, "uploader": "Cryptoverse", "uploader_id": "@cryptoverse2022", "uploader_url": "https://www.youtube.com/@cryptoverse2022", "upload_date": "20230326", "timestamp": 1679853500, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "DMgeFRtqpkA", "fulltitle": "Intervju tjedna, Vedran Vukman - CEO Revuto", "duration_string": "48:23", "is_live": false, "was_live": false, "epoch": 1779977124, "format": "134 - 640x360 (360p)+251 - audio only (medium)", "format_id": "134+251", "ext": "mkv", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 118084482, "tbr": 325.385, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dynamic_range": "SDR", "vcodec": "avc1.4d401e", "vbr": 197.881, "aspect_ratio": 1.78, "acodec": "opus", "abr": 127.504, "asr": 48000, "audio_channels": 2, "_type": "video", "_version": {"version": "2026.04.10.235301", "release_git_head": "2c28ee5d76d2c0d350407fd81dbdd71394b67993", "repository": "yt-dlp/yt-dlp-nightly-builds"}}