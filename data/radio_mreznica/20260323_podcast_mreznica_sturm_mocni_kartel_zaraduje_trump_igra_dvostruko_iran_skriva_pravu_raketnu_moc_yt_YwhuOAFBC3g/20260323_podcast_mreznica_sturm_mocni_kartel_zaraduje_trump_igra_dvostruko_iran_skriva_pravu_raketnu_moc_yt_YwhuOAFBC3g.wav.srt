236
00:20:44,520 --> 00:20:45,660
 lijevo,

237
00:20:45,660 --> 00:20:46,380
 desno,

238
00:20:46,380 --> 00:20:47,000
 gore,

239
00:20:47,000 --> 00:20:47,700
 dole,

240
00:20:47,700 --> 00:20:48,960
 putnički avion,

241
00:20:48,960 --> 00:20:49,680
 mlazni,

242
00:20:49,680 --> 00:20:50,160
 pazite,

243
00:20:50,160 --> 00:20:50,980
 mlazni avion,

244
