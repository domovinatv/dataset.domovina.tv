atraktivnlm, te ni na svoju djecu ne prenose prave kršćanske vrijednosti. \nDa vjera može biti itekako zanimljiva i koji je poziv današnjih očeva poučit će nas ovo predavanje Matije Ricova, voditelja zajednice Nanovo rođeni.\n\nNanovo rođeni je katolička karizmatska molitvena zajednica kojoj su glavni ciljevi cjelovita formacija mladih katolika i evangelizacija.\n\nRad zajednice možete podržati uplatom na IBAN udruge Nanovo rođeni: HR7824840081135098183.\n\nInstagram profil: https://instagram.com/nanovo_rodjeni?utm_medium=copy_link\nFacebook profil: https://m.facebook.com/Nanovo-ro%C4%91eni-1046403725381309/?tsid=0.4593085457522492&source=result", "channel_id": "UCiXXRMlzoA-MKPHVe5V7YdQ", "channel_url": "https://www.youtube.com/channel/UCiXXRMlzoA-MKPHVe5V7YdQ", "duration": 4173, "view_count": 4333, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=waPWdN8UMhg", "categories": ["Education"], "tags": ["Nanovo", "rođeni", "Matija", "Ricov", "Poziv na očinstvo", "Očevi", "Božja pobjeda", "Duhovni kutak", "Mladi kristofori", "Laudato", "Mijo Barada"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "channel": "Nanovo rođeni", "channel_follower_count": 47900, "uploader": "Nanovo rođeni", "uploader_id": "@nanovoroeni3392", "uploader_url": "https://www.youtube.com/@nanovoroeni3392", "upload_date": "20180806", "timestamp": 1533543740, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "waPWdN8UMhg", "fulltitle": "Matija Ricov - Poziv na očinstvo", "duration_string": "1:09:33", "is_live": false, "was_live": false, "epoch": 1771513695, "format": "243 - 640x360 (360p)+140 - audio only (medium)", "format_id": "243+140", "ext": "mkv", "protocol": "https+https", "format_