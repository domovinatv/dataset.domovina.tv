1226
00:48:43,720 --> 00:48:45,920
 znaš ono,

1227
00:48:45,920 --> 00:48:46,880
 mislim se,

1228
00:48:46,880 --> 00:48:47,320
 Bože,

1229
00:48:47,320 --> 00:48:47,840
 dragi,

1230
00:48:47,840 --> 00:48:47,960
 pa,

1231
00:48:47,960 --> 00:48:49,180
 ja sam čutila,

1232
00:48:49,180 --> 00:48:51,040
 da je to nešto skroz drugo,

1233
00:48:51,040 --> 00:48:53,880
 skroz drugo,

1234
00:48:53,880 --> 00:48:55,580
 nisam znala šta je,

1235
00:48:55,580 --> 00:48:57,760
 sam znala da je to treba drugačije,

1236
00:48:57,760 --> 00:48:58,680
 šta je to drugačije,

1237
00:48:58,680 --> 00:48:59,380
 ja ne znam,

1238
00:48:59,540 --> 00:49:02,280
 ja sada,

1239
00:49:02,280 --> 00:49:04,020
