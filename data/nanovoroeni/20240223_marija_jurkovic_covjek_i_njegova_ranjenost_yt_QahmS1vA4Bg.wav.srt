1212
00:48:31,360 --> 00:48:32,140
 tako dedo,

1213
00:48:32,140 --> 00:48:32,640
 tako baba,

1214
00:48:32,640 --> 00:48:33,140
 tako mama,

1215
00:48:33,140 --> 00:48:33,680
 tako tata,

1216
00:48:33,680 --> 00:48:34,380
 tako fratari,

1217
00:48:34,380 --> 00:48:34,900
