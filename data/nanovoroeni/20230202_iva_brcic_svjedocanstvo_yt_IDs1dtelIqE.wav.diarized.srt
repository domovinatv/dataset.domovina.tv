[SPEAKER_00] pa ćete ući u blagdan ovoga,

967
00:55:56,920 --> 00:55:57,599
[SPEAKER_00] bezgrišno,

968
00:55:57,599 --> 00:55:58,920
[SPEAKER_00] odnosno uznesenja

969
00:55:58,920 --> 00:56:00,860
[SPEAKER_00] Blažene Djevice Marije,

970
00:56:00,860 --> 00:56:01,739
[SPEAKER_00] vjenčali smo se,

971
00:56:01,739 --> 00:56:02,960
[SPEAKER_00] i,

972
00:56:02,960 --> 00:56:04,539
[SPEAKER_00] mislim,

973
00:56:04,539 --> 00:56:05,440
[SPEAKER_00] predivno,

974
00:56:05,440 --> 00:56:05,699
[SPEAKER_00] evo,

975
00:56:05,699 --> 00:56:06,800
[SPEAKER_00] taj sakrament braka,

976
00:56:06,800 --> 00:56:07,599
[SPEAKER_00] taj sam čin,

977
00:56:07,599 --> 00:56:08,159
[SPEAKER_00] znači,

978
00:56:08,159 --> 00:56:10,940
[SPEAKER_00] običanja koje sam ja dala njemu,

979
00:56:10,940 --> 00:56:11,440
[SPEAKER_00] ja danas,

980
00:56:11,440 --> 00:56:11,659
[SPEAKER_00] evo,

981
00:56:11,659 --> 00:56:13,360
[SPEAKER_00] 18 godina smo prošli braka,

982
00:56:13,360 --> 00:56:15,219
[SPEAKER_00] ja još uvijek to živo nosim u sebi,

983
00:56:15,219 --> 00:56:16,219
[SPEAKER_00] to je nešto predivno,

984
00:56:16,219 --> 00:56:19,119
[SPEAKER_00] odnosno se otvorili za život,

985
00:56:19,119 --> 00:56:20,179
[SPEAKER_00] i rekli smo gospodine,

986
00:56:20,179 --> 00:56:21,280
[SPEAKER_00] nemamo stalan posao,

987
00:56:21,280 --> 00:56:22,059
[SPEAKER_00] nemamo stana,

988
00:56:22,059 --> 00:56:22,460
[SPEAKER_00] ali evo,

989
00:56:22,460 --> 00:56:23,199
[SPEAKER_00] mi smo tu,

990
00:56:23,199 --> 00:56:23,920
[SPEAKER_00] ti čini,

991
00:56:23,920 --> 00:56:25,719
[SPEAKER_00] ostala sam brzo trudna,

992
00:56:25,719 --> 00:56:26,900
[SPEAKER_00] sa prvim sinom,

993
00:56:26,900 --> 00:56:28,039
[SPEAKER_00] dobili smo posao,

994
00:56:28,039 --> 00:56:29,420
[SPEAKER_00] jedan i drugi odmah za stalno,

995
00:56:29,420 --> 00:56:31,619
[SPEAKER_00] ali onda sam ja morila ići na porodini,

996
00:56:31,619 --> 00:56:32,900
[SPEAKER_00] pa nisu baš bili sretni,

997
00:56:32,900 --> 00:56:33,980
[SPEAKER_00] pa onda,

998
00:56:33,980 --> 00:56:35,159
[SPEAKER_00] nakon godinu i polja,

999
00:56:35,159 --> 00:56:35,960
[SPEAKER_00] opet trudna,

1000
00:56:35,960 --> 00:56:37,699
[SPEAKER_00] rodim drugog sina,

1001
00:56:37,699 --> 00:56:39,500
[SPEAKER_00] onda ovina poslović stvarno ono kao,

1002
00:56:39,500 --> 00:56:40,780
[SPEAKER_00] pa kako ti djece misliš,

1003
00:56:40,780 --> 00:56:41,780
[SPEAKER_00] kao imat,

1004
00:56:41,780 --> 00:56:44,519
[SPEAKER_00] radila sam u jednoj autoindustriji,

1005
00:56:44,519 --> 00:56:46,139
[SPEAKER_00] gdje samo posao,

1006
00:56:46,139 --> 00:56:46,480
[SPEAKER_00] posao,

1007
00:56:46,480 --> 00:56:47,639
[SPEAKER_00] posao i ovoga,

1008
00:56:47,639 --> 00:56:49,780
[SPEAKER_00] ja sam onako iskreno,

1009
00:56:49,780 --> 00:56:51,019
[SPEAKER_00] kako mi zajednica naučila,

1010
00:56:51,019 --> 00:56:51,579
[SPEAKER_00] rekla,

1011
00:56:51,579 --> 00:56:52,579
[SPEAKER_00] puno djece,

1012
00:56:52,579 --> 00:56:54,420
[SPEAKER_00] ja sam dobila otkaz,

1013
00:56:54,420 --> 00:56:54,900
[SPEAKER_00] okej,

1014
00:56:54,900 --> 00:56:56,119
[SPEAKER_00] nisam trebala biti iskrena,

1015
00:56:56,119 --> 00:56:58,960
[SPEAKER_00] mogla sam to nekako diplomatski izbijeć,

1016
00:56:58,960 --> 00:56:59,539
[SPEAKER_00] ali ne veze,

1017
00:56:59,539 --> 00:57:02,860
[SPEAKER_00] mi smo išli u Međugorje na susret eksovaca,

1018
00:57:02,860 --> 00:57:05,599
[SPEAKER_00] znači jednogodišnje se iz cijelog svijeta

1019
00:57:05,599 --> 00:57:07,280
[SPEAKER_00] okupljaju djeca zajednice,

1020
00:57:07,699 --> 00:57:08,960
[SPEAKER_00] odlučila živjet vani

1021
00:57:08,960 --> 00:57:10,579
[SPEAKER_00] i ponje tu duhovnost van

1022
00:57:10,579 --> 00:57:12,420
[SPEAKER_00] i kad smo došli u Međugorje,

1023
00:57:12,420 --> 00:57:14,239
[SPEAKER_00] molit za još jedno djete,

1024
00:57:14,239 --> 00:57:15,300
[SPEAKER_00] bila Elvira tamo

1025
00:57:15,300 --> 00:57:16,460
[SPEAKER_00] i vidjeli smo joj,

1026
00:57:16,460 --> 00:57:17,380
[SPEAKER_00] zagrlili se s njom

1027
00:57:17,380 --> 00:57:18,239
[SPEAKER_00] i pitala nas je,

1028
00:57:18,239 --> 00:57:19,719
[SPEAKER_00] kako imate djece,

1029
00:57:19,719 --> 00:57:20,719
[SPEAKER_00] smo rekli dvoje,

1030
00:57:20,719 --> 00:57:21,219
[SPEAKER_00] ona rekla,

1031
00:57:21,219 --> 00:57:22,940
[SPEAKER_00] odite sad na podbrdo se molit,

1032
00:57:22,940 --> 00:57:23,940
[SPEAKER_00] a ja sam mladinu rekla,

1033
00:57:23,940 --> 00:57:25,219
[SPEAKER_00] ja se molim za curicu.

1034
00:57:25,219 --> 00:57:26,019
[SPEAKER_00] Bedruo,

1035
00:57:26,019 --> 00:57:26,840
[SPEAKER_00] Iva nije važno,

1036
00:57:26,840 --> 00:57:27,159
[SPEAKER_00] mislim,

1037
00:57:27,159 --> 00:57:28,199
[SPEAKER_00] djeca su djeca,

1038
00:57:28,199 --> 00:57:29,679
[SPEAKER_00] ja želim djevojčicu,

1039
00:57:29,679 --> 00:57:30,800
[SPEAKER_00] molim te.

1040
00:57:30,800 --> 00:57:32,280
[SPEAKER_00] Došli smo na podbrdo

1041
00:57:32,280 --> 00:57:33,260
[SPEAKER_00] i molili smo se

1042
00:57:33,260 --> 00:57:34,179
[SPEAKER_00] za djevojčicu,

1043
00:57:34,179 --> 00:57:35,860
[SPEAKER_00] iako smo rekli ono,

1044
00:57:35,860 --> 00:57:37,940
[SPEAKER_00] ako moguće da ti malo

1045
00:57:37,940 --> 00:57:38,659
[SPEAKER_00] urgiraš,

1046
00:57:38,659 --> 00:57:40,500
[SPEAKER_00] da Bog ipak nama da curicu,

1047
00:57:40,500 --> 00:57:41,579
[SPEAKER_00] jer sad nakon dva sina,

1048
00:57:41,579 --> 00:57:43,099
[SPEAKER_00] ja bih stvarno htjela curicu.

1049
00:57:43,099 --> 00:57:45,019
[SPEAKER_00] I devet mjeseci kasnije

1050
00:57:45,019 --> 00:57:46,199
[SPEAKER_00] rodila se naša Mirjam,

1051
00:57:46,199 --> 00:57:50,679
[SPEAKER_00] na 25. u mjesecu,

1052
00:57:50,679 --> 00:57:51,920
[SPEAKER_00] kada Gospa objavljuje

1053
00:57:51,920 --> 00:57:53,579
[SPEAKER_00] svoje poruke u Međugorju,

1054
00:57:53,579 --> 00:57:54,920
[SPEAKER_00] dali smo ime po Gospi.

1055
00:57:54,920 --> 00:57:58,179
[SPEAKER_00] Eto, nešto predivno,

1056
00:57:58,179 --> 00:57:59,500
[SPEAKER_00] znači dobila sam tu curicu,

1057
00:57:59,500 --> 00:58:00,840
[SPEAKER_00] kasnije je došao još jedan sin,

1058
00:58:01,400 --> 00:58:01,880
[SPEAKER_00] treći,

1059
00:58:01,880 --> 00:58:04,739
[SPEAKER_00] život nakon zajednice,

1060
00:58:04,739 --> 00:58:06,519
[SPEAKER_00] naš u braku je bio predivan,

1061
00:58:06,519 --> 00:58:07,039
[SPEAKER_00] odnosno,

1062
00:58:07,039 --> 00:58:08,219
[SPEAKER_00] tako smo ga postavili,

1063
00:58:08,219 --> 00:58:09,480
[SPEAKER_00] želimo živjeti za Krista,

1064
00:58:09,480 --> 00:58:11,059
[SPEAKER_00] želimo nositi tu radost svima,

1065
00:58:11,059 --> 00:58:12,340
[SPEAKER_00] želimo svjedočiti,

1066
00:58:12,340 --> 00:58:13,920
[SPEAKER_00] tako da smo ovih 20 godina,

1067
00:58:13,920 --> 00:58:14,739
[SPEAKER_00] od kad smo vani,

1068
00:58:14,739 --> 00:58:16,840
[SPEAKER_00] jedan i drugi stalno svjedočili,

1069
00:58:16,840 --> 00:58:19,079
[SPEAKER_00] i skupa svjedočili kao par,

1070
00:58:19,079 --> 00:58:21,539
[SPEAKER_00] i vodili tu našu dječicu sa sobom,

1071
00:58:21,539 --> 00:58:23,599
[SPEAKER_00] mnoge mlade spremili u zajednicu,

1072
00:58:23,599 --> 00:58:25,360
[SPEAKER_00] i bili, ono,

1073
00:58:25,360 --> 00:58:27,340
[SPEAKER_00] i roditelji,

1074
00:58:27,340 --> 00:58:28,699
[SPEAKER_00] i duhovni pratitelji,

1075
00:58:28,699 --> 00:58:29,480
[SPEAKER_00] i prijatelji,

1076
00:58:29,480 --> 00:58:30,480
[SPEAKER_00] i podrška braća,

1077
00:58:30,559 --> 00:58:31,340
[SPEAKER_00] sestre u Kristu,

1078
00:58:31,340 --> 00:58:33,780
[SPEAKER_00] sve za nekog koji je bio u potrebi,

1079
00:58:33,780 --> 00:58:35,480
[SPEAKER_00] i to je zapravo smisao,

1080
00:58:35,480 --> 00:58:36,760
[SPEAKER_00] eto, tog života našeg,

1081
00:58:36,760 --> 00:58:38,019
[SPEAKER_00] jer besplatno primi smo,

1082
00:58:38,019 --> 00:58:39,840
[SPEAKER_00] besplatno i želimo davati.

1083
00:58:39,840 --> 00:58:42,260
[SPEAKER_00] Vidim da sam tu zapisala

1084
00:58:42,260 --> 00:58:43,139
[SPEAKER_00] šta smo sve radili,

1085
00:58:43,139 --> 00:58:44,480
[SPEAKER_00] ali možda nije toliko bitno,

1086
00:58:44,480 --> 00:58:45,639
[SPEAKER_00] ali hoću reći da smo

1087
00:58:45,639 --> 00:58:47,280
[SPEAKER_00] tamo na svjetom duhu,

1088
00:58:47,280 --> 00:58:48,940
[SPEAKER_00] gdje smo mi zmoli prvu krunicu,

1089
00:58:48,940 --> 00:58:49,639
[SPEAKER_00] i vjenčali se,

1090
00:58:49,639 --> 00:58:50,539
[SPEAKER_00] baš zbog toga,

1091
00:58:50,539 --> 00:58:52,420
[SPEAKER_00] organizirali deset godina

1092
00:58:52,420 --> 00:58:54,000
[SPEAKER_00] susrete za eksovce,

1093
00:58:54,000 --> 00:58:55,639
[SPEAKER_00] znači svi koji izađu iz zajednice,

1094
00:58:56,019 --> 00:58:57,679
[SPEAKER_00] su dolazili subotama tamo,

1095
00:58:57,679 --> 00:59:00,739
[SPEAKER_00] i molili bi se živjeli tu duhovnost zajednice,

1096
00:59:00,739 --> 00:59:01,940
[SPEAKER_00] onda je to nekako malo zamrlo,

1097
00:59:01,940 --> 00:59:03,400
[SPEAKER_00] svi smo počeli imati puno djece,

1098
00:59:03,400 --> 00:59:04,159
[SPEAKER_00] mi još najmanje,

1099
00:59:04,159 --> 00:59:04,860
[SPEAKER_00] jedni osam,

1100
00:59:04,860 --> 00:59:05,519
[SPEAKER_00] jedni sedam,

1101
00:59:05,519 --> 00:59:06,340
[SPEAKER_00] mi samo četiri,

1102
00:59:06,340 --> 00:59:06,739
[SPEAKER_00] ali dobro.

1103
00:59:08,800 --> 00:59:10,360
[SPEAKER_00] Organizirali smo i klanjanja tamo,

1104
00:59:10,360 --> 00:59:11,460
[SPEAKER_00] baš gdje Stjepan Brčina,

1105
00:59:11,460 --> 00:59:12,400
[SPEAKER_00] koji bio naš gost,

1106
00:59:12,400 --> 00:59:13,840
[SPEAKER_00] isto sad mladi tamo slave,

1107
00:59:13,840 --> 00:59:16,079
[SPEAKER_00] mi smo organizirali jednomjesečno klanjanja

1108
00:59:16,079 --> 00:59:18,039
[SPEAKER_00] za roditelje čija su djeca bila,

1109
00:59:18,039 --> 00:59:20,179
[SPEAKER_00] jesu ili će se tek spremaju za zajednicu,

1110
00:59:20,179 --> 00:59:21,400
[SPEAKER_00] mislim, stvarno,

1111
00:59:21,400 --> 00:59:22,260
[SPEAKER_00] toliko plodeva,

1112
00:59:22,260 --> 00:59:24,219
[SPEAKER_00] toliko lijepih darova,

1113
00:59:24,219 --> 00:59:24,960
[SPEAKER_00] lijepih stvari,

1114
00:59:24,960 --> 00:59:27,019
[SPEAKER_00] evo taj život u gospodinu

1115
00:59:27,019 --> 00:59:27,760
[SPEAKER_00] i s gospodinom,

1116
00:59:27,760 --> 00:59:28,840
[SPEAKER_00] da se to ne može mjeriti

1117
00:59:28,840 --> 00:59:29,679
[SPEAKER_00] s ni jednim poslom,

1118
00:59:29,679 --> 00:59:30,900
[SPEAKER_00] ni jednom naslovnicom,

1119
00:59:30,900 --> 00:59:32,539
[SPEAKER_00] ni kampanjom prije,

1120
00:59:32,579 --> 00:59:34,559
[SPEAKER_00] ne mogu niti uspoređivati,

1121
00:59:34,559 --> 00:59:36,860
[SPEAKER_00] ali htjela sam isto posvjedočiti,

1122
00:59:36,860 --> 00:59:37,920
[SPEAKER_00] jer je to jako važno.

1123
00:59:37,920 --> 00:59:39,639
[SPEAKER_00] Život,

1124
00:59:39,639 --> 00:59:41,880
[SPEAKER_00] moj život uz Krista

1125
00:59:41,880 --> 00:59:43,420
[SPEAKER_00] i naš život kao obitelji

1126
00:59:43,420 --> 00:59:44,420
[SPEAKER_00] nije bio uvijek lagan.

1127
00:59:44,420 --> 00:59:47,199
[SPEAKER_00] Mi se molimo za providnost

1128
00:59:47,199 --> 00:59:49,199
[SPEAKER_00] i vjerujemo u providnost,

1129
00:59:49,199 --> 00:59:50,840
[SPEAKER_00] nikad nije ništa uzmanjkalo,

1130
00:59:50,840 --> 00:59:53,460
[SPEAKER_00] ali ne želimo imati gomilu.

1131
00:59:53,460 --> 00:59:55,500
[SPEAKER_00] Trudimo se biti skromni

1132
00:59:55,500 --> 00:59:56,619
[SPEAKER_00] i dijeliti sa drugima,

1133
00:59:56,619 --> 00:59:58,619
[SPEAKER_00] ali bilo je tu i križeva

1134
00:59:58,619 --> 01:00:00,599
