00:54:56,640 --> 00:54:57,420
 ja sam plakala,

928
00:54:57,420 --> 00:55:00,040
 par dana kasnije sam se vratila u Zagreb,

929
00:55:00,040 --> 00:55:00,980
 da sad skratim priču,

930
00:55:00,980 --> 00:55:02,120
 ne znam koliko imamo vremena,

931
00:55:02,120 --> 00:55:03,220
 uf,

932
00:55:03,220 --> 00:55:06,120
 sad trebam ovih zadnjih 18 godina,

933
00:55:06,120 --> 00:55:07,960
 što više,

934
00:55:07,960 --> 00:55:09,580
 da,

935
00:55:09,580 --> 00:55:10,700
 komprimirati,

936
00:55:10,700 --> 00:55:11,180
 dakle,

937
00:55:11,180 --> 00:55:13,060
 izašla je zajednice,

938
00:55:13,060 --> 00:55:14,460
 mladin se meni javio,

939
00:55:14,460 --> 00:55:14,820
 ja sam rekla,

940
00:55:14,820 --> 00:55:15,180
 gospodine,

941
00:55:15,180 --> 00:55:16,320
 neću se na njemu javljati,

942
00:55:16,320 --> 00:55:17,860
 ako si ti to zakuhala,

943
00:55:17,860 --> 00:55:19,500
 ti mu reci da sam došla u Zagreb.

944
00:55:19,500 --> 00:55:20,860
 I on je saznao,

945
00:55:20,860 --> 00:55:22,840
 ja sam izašla na bezgrišno za Čeće,

946
00:55:22,840 --> 00:55:24,000
 za ome,

947
00:55:25,760 --> 00:55:26,920
 i za nove godine,

948
00:55:26,920 --> 00:55:29,960
 već smo 31. na Don Boska bili zaručeni,

949
00:55:29,960 --> 00:55:30,360
 jer ono,

950
00:55:30,360 --> 00:55:32,180
 nevam šta čeka,

951
00:55:32,180 --> 00:55:33,400
 devet mjeseci sam molila,

952
00:55:33,400 --> 00:55:34,120
 samo za njega,

953
00:55:34,120 --> 00:55:34,440
 mislim,

954
00:55:34,440 --> 00:55:36,700
 ja ga poznam bolje nek samu sebe,

955
00:55:36,700 --> 00:55:37,620
 tako da,

956
00:55:37,620 --> 00:55:39,380
 brzo je to išlo,

957
00:55:39,380 --> 00:55:40,400
 poznali smo se,

958
00:55:40,400 --> 00:55:41,640
 postali smo prijatelji,

959
00:55:41,640 --> 00:55:43,100
 brzo smo se zaručili,

960
00:55:43,100 --> 00:55:46,540
 15.8. smo htjeli vjenčanje pripremiti,

961
00:55:46,540 --> 00:55:49,880
 a bude u čast Djevici Mariji,

962
00:55:49,880 --> 00:55:50,980
 i na njezin dan,

963
00:55:50,980 --> 00:55:51,800
 ali je bila nedjelja,

964
00:55:51,800 --> 00:55:53,540
 pa su nas uvjeravali,

965
00:55:53,540 --> 00:55:55,040
 dajte na kolbe,

966
00:55:55,120 --> 00:55:56,920
 pa ćete ući u blagdan ovoga,

967
00:55:56,920 --> 00:55:57,600
 bezgrišno,

968
00:55:57,600 --> 00:55:58,920
 odnosno uznesenja

969
00:55:58,920 --> 00:56:00,860
 Blažene Djevice Marije,

970
00:56:00,860 --> 00:56:01,740
 vjenčali smo se,

971
00:56:01,740 --> 00:56:02,960
 i,

972
00:56:02,960 --> 00:56:04,540
 mislim,

973
00:56:04,540 --> 00:56:05,440
 predivno,

974
00:56:05,440 --> 00:56:05,700
 evo,

975
00:56:05,700 --> 00:56:06,800
 taj sakrament braka,

976
00:56:06,800 --> 00:56:07,600
 taj sam čin,

977
00:56:07,600 --> 00:56:08,160
 znači,

978
00:56:08,160 --> 00:56:10,940
 običanja koje sam ja dala njemu,

979
00:56:10,940 --> 00:56:11,440
 ja danas,

980
00:56:11,440 --> 00:56:11,660
 evo,

981
00:56:11,660 --> 00:56:13,360
 18 godina smo prošli braka,

982
00:56:13,360 --> 00:56:15,220
 ja još uvijek to živo nosim u sebi,

983
00:56:15,220 --> 00:56:16,220
 to je nešto predivno,

984
00:56:16,220 --> 00:56:19,120
 odnosno se otvorili za život,

985
00:56:19,120 --> 00:56:20,180
 i rekli smo gospodine,

986
00:56:20,180 --> 00:56:21,280
 nemamo stalan posao,

987
00:56:21,280 --> 00:56:22,060
 nemamo stana,

988
00:56:22,060 --> 00:56:22,460
 ali evo,

989
00:56:22,460 --> 00:56:23,200
 mi smo tu,

990
00:56:23,200 --> 00:56:23,920
 ti čini,

991
00:56:23,920 --> 00:56:25,720
 ostala sam brzo trudna,

992
00:56:25,720 --> 00:56:26,900
 sa prvim sinom,

993
00:56:26,900 --> 00:56:28,040
 dobili smo posao,

994
00:56:28,040 --> 00:56:29,420
 jedan i drugi odmah za stalno,

995
00:56:29,420 --> 00:56:31,620
 ali onda sam ja morila ići na porodini,

996
00:56:31,620 --> 00:56:32,900
 pa nisu baš bili sretni,

997
00:56:32,900 --> 00:56:33,980
 pa onda,

998
00:56:33,980 --> 00:56:35,160
 nakon godinu i polja,

999
00:56:35,160 --> 00:56:35,960
 opet trudna,

1000
00:56:35,960 --> 00:56:37,700
 rodim drugog sina,

1001
00:56:37,700 --> 00:56:39,500
 onda ovina poslović stvarno ono kao,

1002
00:56:39,500 --> 00:56:40,780
 pa kako ti djece misliš,

1003
00:56:40,780 --> 00:56:41,780
 kao imat,

1004
00:56:41,780 --> 00:56:44,520
 radila sam u jednoj autoindustriji,

1005
00:56:44,520 --> 00:56:46,140
 gdje samo posao,

1006
00:56:46,140 --> 00:56:46,480
 posao,

1007
00:56:46,480 --> 00:56:47,640
 posao i ovoga,

1008
00:56:47,640 --> 00:56:49,780
 ja sam onako iskreno,

1009
00:56:49,780 --> 00:56:51,020
 kako mi zajednica naučila,

1010
00:56:51,020 --> 00:56:51,580
 rekla,

1011
00:56:51,580 --> 00:56:52,580
 puno djece,

1012
00:56:52,580 --> 00:56:54,420
 ja sam dobila otkaz,

1013
00:56:54,420 --> 00:56:54,900
 okej,

1014
00:56:54,900 --> 00:56:56,120
 nisam trebala biti iskrena,

1015
00:56:56,120 --> 00:56:58,960
 mogla sam to nekako diplomatski izbijeć,

1016
00:56:58,960 --> 00:56:59,540
 ali ne veze,

1017
00:56:59,540 --> 00:57:02,860
 mi smo išli u Međugorje na susret eksovaca,

1018
00:57:02,860 --> 00:57:05,600
 znači jednogodišnje se iz cijelog svijeta

1019
00:57:05,600 --> 00:57:07,280
 okupljaju djeca zajednice,

1020
00:57:07,700 --> 00:57:08,960
 odlučila živjet vani

1021
00:57:08,960 --> 00:57:10,580
 i ponje tu duhovnost van

1022
00:57:10,580 --> 00:57:12,420
 i kad smo došli u Međugorje,

1023
00:57:12,420 --> 00:57:14,240
 molit za još jedno djete,

1024
00:57:14,240 --> 00:57:15,300
 bila Elvira tamo

1025
00:57:15,300 --> 00:57:16,460
 i vidjeli smo joj,

1026
00:57:16,460 --> 00:57:17,380
 zagrlili se s njom

1027
00:57:17,380 --> 00:57:18,240
 i pitala nas je,

1028
00:57:18,240 --> 00:57:19,720
 kako imate djece,

1029
00:57:19,720 --> 00:57:20,720
 smo rekli dvoje,

1030
00:57:20,720 --> 00:57:21,220
 ona rekla,

1031
00:57:21,220 --> 00:57:22,940
 odite sad na podbrdo se molit,

1032
00:57:22,940 --> 00:57:23,940
 a ja sam mladinu rekla,

1033
00:57:23,940 --> 00:57:25,220
 ja se molim za curicu.

1034
00:57:25,220 --> 00:57:26,020
 Bedruo,

1035
00:57:26,020 --> 00:57:26,840
 Iva nije važno,

1036
00:57:26,840 --> 00:57:27,160
 mislim,

1037
00:57:27,160 --> 00:57:28,200
 djeca su djeca,

1038
00:57:28,200 --> 00:57:29,680
 ja želim djevojčicu,

1039
00:57:29,680 --> 00:57:30,800
 molim te.

1040
00:57:30,800 --> 00:57:32,280
 Došli smo na podbrdo

1041
00:57:32,280 --> 00:57:33,260
 i molili smo se

1042
00:57:33,260 --> 00:57:34,180
 za djevojčicu,

1043
00:57:34,180 --> 00:57:35,860
 iako smo rekli ono,

1044
00:57:35,860 --> 00:57:37,940
 ako moguće da ti malo

1045
00:57:37,940 --> 00:57:38,660
 urgiraš,

1046
00:57:38,660 --> 00:57:40,500
 da Bog ipak nama da curicu,

1047
00:57:40,500 --> 00:57:41,580
 jer sad nakon dva sina,

1048
00:57:41,580 --> 00:57:43,100
 ja bih stvarno htjela curicu.

1049
00:57:43,100 --> 00:57:45,020
 I devet mjeseci kasnije

1050
00:57:45,020 --> 00:57:46,200
 rodila se naša Mirjam,

1051
00:57:46,200 --> 00:57:50,680
 na 25. u mjesecu,

1052
00:57:50,680 --> 00:57:51,920
 kada Gospa objavljuje

1053
00:57:51,920 --> 00:57:53,580
 svoje poruke u Međugorju,

1054
00:57:53,580 --> 00:57:54,920
 dali smo ime po Gospi.

1055
00:57:54,920 --> 00:57:58,180
 Eto, nešto predivno,

1056
00:57:58,180 --> 00:57:59,500
 znači dobila sam tu curicu,

1057
00:57:59,500 --> 00:58:00,840
 kasnije je došao još jedan sin,

1058
00:58:01,400 --> 00:58:01,880
 treći,

1059
00:58:01,880 --> 00:58:04,740
 život nakon zajednice,

1060
00:58:04,740 --> 00:58:06,520
 naš u braku je bio predivan,

1061
00:58:06,520 --> 00:58:07,040
 odnosno,

1062
00:58:07,040 --> 00:58:08,220
 tako smo ga postavili,

1063
00:58:08,220 --> 00:58:09,480
 želimo živjeti za Krista,

1064
00:58:09,480 --> 00:58:11,060
 želimo nositi tu radost svima,

1065
00:58:11,060 --> 00:58:12,340
 želimo svjedočiti,

1066
00:58:12,340 --> 00:58:13,920
 tako da smo ovih 20 godina,

1067
00:58:13,920 --> 00:58:14,740
 od kad smo vani,

1068
00:58:14,740 --> 00:58:16,840
 jedan i drugi stalno svjedočili,

1069
00:58:16,840 --> 00:58:19,080
 i skupa svjedočili kao par,

1070
00:58:19,080 --> 00:58:21,540
 i vodili tu našu dječicu sa sobom,

1071
00:58:21,540 --> 00:58:23,600
 mnoge mlade spremili u zajednicu,

1072
00:58:23,600 --> 00:58:25,360
 i bili, ono,

1073
00:58:25,360 --> 00:58:27,340
 i roditelji,

1074
00:58:27,340 --> 00:58:28,700
 i duhovni pratitelji,

1075
00:58:28,700 --> 00:58:29,480
 i prijatelji,

1076
00:58:29,480 --> 00:58:30,480
 i podrška braća,

1077
00:58:30,560 --> 00:58:31,340
 sestre u Kristu,

1078
00:58:31,340 --> 00:58:33,780
 sve za nekog koji je bio u potrebi,

1079
00:58:33,780 --> 00:58:35,480
 i to je zapravo smisao,

1080
00:58:35,480 --> 00:58:36,760
 eto, tog života našeg,

1081
00:58:36,760 --> 00:58:38,020
 jer besplatno primi smo,

1082
00:58:38,020 --> 00:58:39,840
 besplatno i želimo davati.

1083
00:58:39,840 --> 00:58:42,260
 Vidim da sam tu zapisala

1084
00:58:42,260 --> 00:58:43,140
 šta smo sve radili,

1085
00:58:43,140 --> 00:58:44,480
 ali možda nije toliko bitno,

1086
00:58:44,480 --> 00:58:45,640
 ali hoću reći da smo

1087
00:58:45,640 --> 00:58:47,280
 tamo na svjetom duhu,

1088
00:58:47,280 --> 00:58:48,940
 gdje smo mi zmoli prvu krunicu,

1089
00:58:48,940 --> 00:58:49,640
 i vjenčali se,

1090
00:58:49,640 --> 00:58:50,540
 baš zbog toga,

1091
00:58:50,540 --> 00:58:52,420
 organizirali deset godina

1092
00:58:52,420 --> 00:58:54,000
 susrete za eksovce,

1093
00:58:54,000 --> 00:58:55,640
 znači svi koji izađu iz zajednice,

1094
00:58:56,020 --> 00:58:57,680
 su dolazili subotama tamo,

1095
00:58:57,680 --> 00:59:00,740
 i molili bi se živjeli tu duhovnost zajednice,

1096
00:59:00,740 --> 00:59:01,940
 onda je to nekako malo zamrlo,

1097
00:59:01,940 --> 00:59:03,400
 svi smo počeli imati puno djece,

1098
00:59:03,400 --> 00:59:04,160
 mi još najmanje,

1099
00:59:04,160 --> 00:59:04,860
 jedni osam,

1100
00:59:04,860 --> 00:59:05,520
 jedni sedam,

1101
00:59:05,520 --> 00:59:06,340
 mi samo četiri,

1102
00:59:06,340 --> 00:59:06,740
 ali dobro.

1103
00:59:08,800 --> 00:59:10,360
 Organizirali smo i klanjanja tamo,

1104
00:59:10,360 --> 00:59:11,460
 baš gdje Stjepan Brčina,

1105
00:59:11,460 --> 00:59:12,400
 koji bio naš gost,

1106
00:59:12,400 --> 00:59:13,840
 isto sad mladi tamo slave,

1107
00:59:13,840 --> 00:59:16,080
 mi smo organizirali jednomjesečno klanjanja

1108
00:59:16,080 --> 00:59:18,040
 za roditelje čija su djeca bila,

1109
00:59:18,040 --> 00:59:20,180
 jesu ili će se tek spremaju za zajednicu,

1110
00:59:20,180 --> 00:59:21,400
 mislim, stvarno,

1111
00:59:21,400 --> 00:59:22,260
 toliko plodeva,

1112
00:59:22,260 --> 00:59:24,220
 toliko lijepih darova,

1113
00:59:24,220 --> 00:59:24,960
 lijepih stvari,

1114
00:59:24,960 --> 00:59:27,020
 evo taj život u gospodinu

1115
00:59:27,020 --> 00:59:27,760
 i s gospodinom,

1116
00:59:27,760 --> 00:59:28,840
 da se to ne može mjeriti

1117
00:59:28,840 --> 00:59:29,680
 s ni jednim poslom,

1118
00:59:29,680 --> 00:59:30,900
 ni jednom naslovnicom,

1119
00:59:30,900 --> 00:59:32,540
 ni kampanjom prije,

1120
00:59:32,580 --> 00:59:34,560
 ne mogu niti uspoređivati,

1121
00:59:34,560 --> 00:59:36,860
 ali htjela sam isto posvjedočiti,

1122
00:59:36,860 --> 00:59:37,920
 jer je to jako važno.

1123
00:59:37,920 --> 00:59:39,640
 Život,

1124
00:59:39,640 --> 00:59:41,880
 moj život uz Krista

1125
00:59:41,880 --> 00:59:43,420
 i naš život kao obitelji

1126
00:59:43,420 --> 00:59:44,420
 nije bio uvijek lagan.

1127
00:59:44,420 --> 00:59:47,200
 Mi se molimo za providnost

1128
00:59:47,200 --> 00:59:49,200
 i vjerujemo u providnost,

1129
00:59:49,200 --> 00:59:50,840
 nikad nije ništa uzmanjkalo,

1130
00:59:50,840 --> 00:59:53,460
 ali ne želimo imati gomilu.

1131
00:59:53,460 --> 00:59:55,500
 Trudimo se biti skromni

1132
00:59:55,500 --> 00:59:56,620
 i dijeliti sa drugima,

1133
00:59:56,620 --> 00:59:58,620
 ali bilo je tu i križeva

1134
00:59:58,620 --> 01:00:00,600
 koje želim samo spomenuti,

1135
01:00:00,600 --> 01:00:03,040
 gdje je gospodin se objavio

1136
01:00:03,040 --> 01:00:03,960
 u svojoj ljubavi

1137
01:00:03,960 --> 01:00:04,900
 i u svojoj dobroti,

1138
01:00:04,900 --> 01:00:07,400
 jer kao što sam i nekako mislila

1139
01:00:07,400 --> 01:00:08,680
 da ova tema već razbude,

1140
01:00:08,680 --> 01:00:11,600
 Bog okreće na dobro

1141
01:00:11,600 --> 01:00:13,400
 sve onima koji ga ljube.

1142
01:00:13,400 --> 01:00:15,640
 Čistog iskrenog srca

1143
01:00:15,640 --> 01:00:17,340
 desio se tu trenutak

1144
01:00:17,340 --> 01:00:19,360
 kad je naš mlađi sin

1145
01:00:19,360 --> 01:00:21,800
 jedne zime pao

1146
01:00:21,800 --> 01:00:22,980
 sa atomskog skloništa

1147
01:00:22,980 --> 01:00:25,320
 sa 6-7 metara visine

1148
01:00:25,320 --> 01:00:30,480
 i ostao ležat,

1149
01:00:30,480 --> 01:00:32,060
 nepokretan, nepomičan.

1150
01:00:32,060 --> 01:00:33,420
 Ja sam dotrčala,

1151
01:00:33,420 --> 01:00:34,800
 došla je hitna jako brzo,

1152
01:00:34,800 --> 01:00:35,800
 mi rekli su ne znam,

1153
01:00:35,800 --> 01:00:37,200
 jako je visoko.

1154
01:00:37,200 --> 01:00:40,360
 Bruno je bio u bolnici,

1155
01:00:40,360 --> 01:00:42,200
 sve pretrage su prošli,

1156
01:00:42,200 --> 01:00:42,700
 napravili.

1157
01:00:42,700 --> 01:00:45,120
 Moj prvi onako instinkt

1158
01:00:45,120 --> 01:00:46,200
 kad sam došla do njega

1159
01:00:46,200 --> 01:00:47,200
 i vidla ga da leži

1160
01:00:47,200 --> 01:00:49,380
 i da ne miče ni ruke ni noge,

1161
01:00:49,380 --> 01:00:50,660
 znači možda je nepokretan,

1162
01:00:50,660 --> 01:00:51,320
 možda je slomio kralježnicu,

1163
01:00:51,320 --> 01:00:51,900
 kralježnicu,

1164
01:00:51,900 --> 01:00:52,680
 ja sam pogledala nebo,

1165
01:00:52,680 --> 01:00:53,300
 rekla sam Bože,

1166
01:00:53,300 --> 01:00:54,000
 ja sam spremna.

1167
01:00:54,000 --> 01:00:56,080
 Ja sve prihvaćam,

1168
01:00:56,080 --> 01:00:56,660
 ja te ljubim

1169
01:00:56,660 --> 01:00:57,700
 i samo mi daj snage

1170
01:00:57,700 --> 01:00:59,300
 da nosim taj svoj križ.

1171
01:00:59,300 --> 01:01:01,400
 To me upravo naučila zajednica.

1172
01:01:01,400 --> 01:01:04,160
 Život je ljep,

1173
01:01:04,160 --> 01:01:05,920
 ima malih križeva,

1174
01:01:05,920 --> 01:01:06,720
 većih križeva,

1175
01:01:06,720 --> 01:01:07,520
 ima teškoća,

1176
01:01:07,520 --> 01:01:09,180
 ali mi te križeve ne smijemo.

1177
01:01:09,180 --> 01:01:09,840
 Ja sam naučila,

1178
01:01:09,840 --> 01:01:11,060
 ja ga ne smijem nositi

1179
01:01:11,060 --> 01:01:12,360
 i vuče za sobom.

1180
01:01:12,360 --> 01:01:13,800
 Želim taj svaki svoj križ

1181
01:01:13,800 --> 01:01:14,760
 zagrliti i ljubiti,

1182
01:01:14,760 --> 01:01:16,420
 jer gospodin mi ga daruje

1183
