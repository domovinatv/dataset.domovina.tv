: "39"}, {"url": "https://i.ytimg.com/vi/EMysWtGLQw0/sddefault.jpg", "preference": -5, "id": "40"}, {"url": "https://i.ytimg.com/vi_webp/EMysWtGLQw0/sddefault.webp", "preference": -4, "id": "41"}, {"url": "https://i.ytimg.com/vi/EMysWtGLQw0/hq720.jpg", "preference": -3, "id": "42"}, {"url": "https://i.ytimg.com/vi_webp/EMysWtGLQw0/hq720.webp", "preference": -2, "id": "43"}, {"url": "https://i.ytimg.com/vi/EMysWtGLQw0/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "44", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/EMysWtGLQw0/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "45", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/EMysWtGLQw0/maxresdefault.webp", "description": "Na susretu zajednice Nanovo rođeni 11. ožujka 2018. imali smo priliku slušati Michelle Moran. Predstavila nam je smjernice pape Franje za naš pokret i nakon toga pokušala probuditi još veći žar za evangelizacijom.\n\nMichelle Moran je bivša predsjednica ICCRS-a (Međunarodne službe Katoličke karizmatske obnove iz Vatikana), te predsjednica Nacionalnog vijeća Katoličke karizmatske obnove u Engleskoj i Walesu.\nGodine 2007. papa Benedikt XVI. postavio ju je za članicu Papinskog vijeća za laike.\nMichelle je, zajedno sa suprugom Peterom, jedan od osnivača Katoličke zajednice za evangelizaciju SION (1984.) Prije nego što se punovremeno posvetila zajednici SION, pet je godina predavala na sveučilištu. Godine 1988. magistrirala je pastoralnu teologiju na Cambridge Theological Federation s temom Vodstvo i služenje u katoličkim župama.\n\nNanovo rođeni je katolička karizmatska molitvena zajednica kojoj su glavni ciljevi cjelovita formacija mladih katolika i evangelizacija.\n\n\nŽELITE LI PODRŽATI RAD ZAJEDNICE I BITI UKLJUČENI U PROVEDBI NAŠE MISIJE?\n\nMožete nas podržati na sljedeće načine:\n\n🔹 STRIPE – omogućuje jednostavne mjesečne donacije: https://buy.stripe.com/00g15l9li6VS9Xy001\n\n🔹 PATREON – uz mjesečne donacije omogućuje i primanje naših obavijesti: https://www.patreon.com/nanovorodeni?utm_campaign=creatorshare_fan\n\n🔹 BANKOVNI RAČUN – direktna uplata ili trajni nalog:\n        IBAN: HR7824840081135098183\n        Primatelj: NR\n        SWIFT (BIC): RZBHHR2X\n        Opis plaćanja: donacija\n\n\nhttp://instagram.com/nanovo_rodjeni\nhttp://facebook.com/nanovorodjeni1", "channel_id": "UCiXXRMlzoA-MKPHVe5V7YdQ", "channel_url": "https://www.youtube.com/channel/UCiXXRMlzoA-MKPHVe5V7YdQ", "duration": 2170, "view_count": 3811, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=EMysWtGLQw0", "categories": ["Education"], "tags": ["Michelle Moran", "Evangelizacija", "Nanovo", "rođeni", "Nanovo rođeni", "Matija", "Ricov", "Božja pobjeda", "Duhovni kutak", "Laudato", "Karizmatski pokret", "Ivica Berdik"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 96, "channel": "Nanovo rođeni", "channel_follower_count": 47900, "uploader": "Nanovo rođeni", "uploader_id": "@nanovoroeni3392", "uploader_url": "https://www.youtube.com/@nanovoroeni3392", "upload_date": "20180322", "timestamp": 1521710650, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "EMysWtGLQw0", "fulltitle": "Michelle Moran - Evangelizacija", "duration_string": "36:10", "is_live": false, "was_live": false, "epoch": 1771514080, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 63068500, "tbr": 232.546, "width": 640, "height": 360, "resolution": "640x360", "fps": 24, "dynamic_range": "SDR", "vcodec": "vp9", "vbr": 119.222, "aspect_ratio": 1.78, "acodec": "opus", "abr":