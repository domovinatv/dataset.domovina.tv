rence": -7, "id": "38", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/TyrhbGVybIM/hqdefault.webp", "preference": -6, "id": "39"}, {"url": "https://i.ytimg.com/vi/TyrhbGVybIM/sddefault.jpg", "preference": -5, "id": "40"}, {"url": "https://i.ytimg.com/vi_webp/TyrhbGVybIM/sddefault.webp", "preference": -4, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/TyrhbGVybIM/hqdefault.jpg", "description": "Gostovanje u župi Botinec.\n\nJohn Pridmore, rođen u istočnom Londonu, u dobi od 10 godina doživio je razvod roditelja i tada je odlučio da više nikoga neće voljeti.\n\nS 13 godina počeo je krasti, u 15. godini već je bio u popravnom domu. Nakon puštanja iz doma, krađa postaje njegov posao. S 19 godina bio je u zatvoru, gdje postaje još ogorčeniji i nasilniji. Po izlasku iz zatvora počinje raditi za neke od najzloglasnijih voditelja organiziranog kriminala u Londonu. Bio je uključen u posao s drogom, reketarenje i kriminal svih vrsta.\n\nImao je novac, moć, djevojke, drogu, ali i dalje mu je nešto nedostajalo. Nakon što je umalo oduzeo život muškarcu u blizini noćnog kluba gdje je radio, nešto se u njemu dogodilo i život mu se počeo mijenjati.  \n\nUskoro je počeo raditi s mladima pokazujući im da je moguć i drugi put. Tijekom nekoliko godina održao je niz predavanja u župama, školama i zatvorima diljem Ujedinjenog Kraljevstva i Irske pred desecima tisuća ljudi svake godine. Među ostalim, govorio je na Svjetskom danu mladih u Sydneyu pred 400.000 mladih i otad je njegovo djelovanje postaje više međunarodno. Predavanja održava u zemljama diljem svijeta poput Švicarske, Njemačke, Nizozemske, Francuske, Italije, Hong Konga, Novog Zelanda, Meksika itd.\n\nSvoje iskreno i dojmljivo svjedočanstvo zabilježio je u knjizi \"Ispovijest londonskoga gangstera\". Knjiga se može nabaviti u Verbumu \nhttps://verbum.hr/knjige/ispovijest-londonskoga-gangstera-5600\n\nNanovo rođeni je katolička karizmatska molitvena zajednica kojoj su glavni ciljevi cjelovita formacija mladih katolika i evangelizacija.\n\nRad zajednice možete podržati uplatom na IBAN udruge Nanovo rođeni: HR7824840081135098183.\n\nInstagram profil: https://instagram.com/nanovo_rodjeni?utm_medium=copy_link\nFacebook profil: https://m.facebook.com/Nanovo-ro%C4%91eni-1046403725381309/?tsid=0.4593085457522492&source=result", "channel_id": "UCiXXRMlzoA-MKPHVe5V7YdQ", "channel_url": "https://www.youtube.com/channel/UCiXXRMlzoA-MKPHVe5V7YdQ", "duration": 2298, "view_count": 5393, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=TyrhbGVybIM", "categories": ["Education"], "tags": ["Nanovo rođeni", "don Josip", "don Damir", "Nova eva", "John Pridmore", "Putovanje u slobodu", "Međugorje", "Božja pobjeda"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 136, "channel": "Nanovo rođeni", "channel_follower_count": 47900, "uploader": "Nanovo rođeni", "uploader_id": "@nanovoroeni3392", "uploader_url": "https://www.youtube.com/@nanovoroeni3392", "upload_date": "20190214", "timestamp": 1550102810, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "TyrhbGVybIM", "fulltitle": "John Pridmore - Izazovi nove evangelizacije [7/8]", "duration_string": "38:18", "is_live": false, "was_live": false, "epoch": 1771512667, "format": "243 - 640x360 (360p)+251 - audio only (medium)", "format_id": "243+251", "ext": "webm", "protocol": "https+https", "format_note": "360p+medium", "filesize_approx": 73532330, "tbr": 256.034, "width": 640, "height": 360, "resolution": "640x360", "fps": 25, "dynamic_range": "SDR", "vcodec": "vp9", "vbr": 141.144, "aspect_ratio": 1.78, "acodec": "opus", "abr": 114.89, "asr": 48000, "audio_channels": 2, "_type": "video", "_version": {"version": "202