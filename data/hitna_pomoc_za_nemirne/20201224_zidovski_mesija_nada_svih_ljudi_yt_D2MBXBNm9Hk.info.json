stavno od muškaraca i žena u koje se zaljubljujemo i od kojih očekujemo da budu ono što oni nisu - Spasitelji?\n\nDošašće i Božić usmjeruju naš pogled na osobu koja bi stvarno mogla biti odgovor na čežnju i očekivanje svih naroda. Kako bi nas uopće mogao spasiti netko tko nas ne spašava iznutra - mjenjajući nam srca? \n\n\n- podaci o rabinu kojemu je objavljeno da je Mesijino ime Isus: https://youtu.be/8jG7gxSPfa8\n- pjesma Ani Maamin na kraju: https://youtu.be/oucFFlau2Vc\n\n#Židovi\n#Mesija\n#DošašćeBožić", "channel_id": "UCnxBjaDEOk_sKtOLp8IM7DA", "channel_url": "https://www.youtube.com/channel/UCnxBjaDEOk_sKtOLp8IM7DA", "duration": 1238, "view_count": 12467, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=D2MBXBNm9Hk", "categories": ["Education"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "release_timestamp": 1608850825, "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {"live_chat": [{"url": "https://www.youtube.com/watch?v=D2MBXBNm9Hk&bpctr=9999999999&has_verified=1", "video_id": "D2MBXBNm9Hk", "ext": "json", "protocol": "youtube_live_chat_replay"}]}, "comment_count": 27, "like_count": 490, "channel": "HITNA POMOĆ ZA NEMIRNE", "channel_follower_count": 12100, "uploader": "HITNA POMOĆ ZA NEMIRNE", "uploader_id": "@hitnapomoczanemirne7345", "uploader_url": "https://www.youtube.com/@hitnapomoczanemirne7345", "upload_date": "20201224", "timestamp": 1608850825, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "D2MBXBNm9Hk", "fulltitle": "Židovski Mesija nada svih ljudi", "duration_string": "20:38", "release_date": "20201224", "release_year": 2020, "is_live": false, "was_live": false, "epoch": 1773757460, "asr": 44100, "format_id": "18", "format_note": "360p", "source_preference": -1, "f