323
00:27:50,940 --> 00:27:51,640
 šta je

324
00:27:51,640 --> 00:27:52,920
 i

325
00:27:52,920 --> 00:27:54,180
 dva dana

326
00:27:54,180 --> 00:27:55,160
 kasnije

327
00:27:55,160 --> 00:27:56,400
 naravno prvo sam pokušao

328
00:27:56,400 --> 00:27:57,280
 sniziti temperaturu

329
00:27:57,280 --> 00:27:59,240
 pomoću razno raznih

330
00:27:59,240 --> 00:28:00,360
 antibiotika

331
00:28:00,360 --> 00:28:02,920
 i drugih sredstva

332
00:28:02,920 --> 00:28:06,080
 i nije se

333
00:28:06,080 --> 00:28:07,160
 spuštala temperatura

334
00:28:07,160 --> 00:28:08,580
 i kasnije

335
00:28:08,580 --> 00:28:09,420
 druga operacija

336
00:28:09,420 --> 00:28:10,080
 bila opet

337
00:28:10,080 --> 00:28:11,560
 uzimanje

338
00:28:11,560 --> 00:28:12,280
 uzoraka

339
00:28:12,280 --> 00:28:14,060
 da se vidi

340
00:28:14,060 --> 00:28:16,480
 što je uzrak

341
00:28:16,480 --> 00:28:17,360
 i

342
00:28:17,360 --> 00:28:19,340
 tu su ustanovali

343
00:28:19,340 --> 00:28:20,400
 da je ta bakterija

344
00:28:20,400 --> 00:28:21,020
 mrsa

345
00:28:21,020 --> 00:28:22,340
 streptokok

346
00:28:22,340 --> 00:28:23,000
 staklokok

347
00:28:23,000 --> 00:28:23,720
 i pseudomonas

348
00:28:23,720 --> 00:28:24,560
 tri bakterije su bile

349
00:28:24,560 --> 00:28:25,980
 i

350
