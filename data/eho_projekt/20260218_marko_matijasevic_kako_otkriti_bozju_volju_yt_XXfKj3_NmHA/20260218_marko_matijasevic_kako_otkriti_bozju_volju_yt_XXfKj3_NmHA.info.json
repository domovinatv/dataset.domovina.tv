GAFwAcABBg==&rs=AOn4CLD5Uv4ap0pIac_x0YAxo1uV-y9VCw", "height": 138, "width": 246, "preference": -7, "id": "32", "resolution": "246x138"}, {"url": "https://i.ytimg.com/vi/XXfKj3_NmHA/hqdefault.jpg?sqp=-oaymwEcCNACELwBSFXyq4qpAw4IARUAAIhCGAFwAcABBg==&rs=AOn4CLDJv35lZg8KeOfwXSzhpKRnEBfUEA", "height": 188, "width": 336, "preference": -7, "id": "33", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/XXfKj3_NmHA/hqdefault.jpg", "height": 360, "width": 480, "preference": -7, "id": "34", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/XXfKj3_NmHA/hqdefault.webp", "preference": -6, "id": "35"}, {"url": "https://i.ytimg.com/vi/XXfKj3_NmHA/sddefault.jpg", "height": 480, "width": 640, "preference": -5, "id": "36", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi_webp/XXfKj3_NmHA/sddefault.webp", "preference": -4, "id": "37"}, {"url": "https://i.ytimg.com/vi/XXfKj3_NmHA/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/XXfKj3_NmHA/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/XXfKj3_NmHA/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "40", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/XXfKj3_NmHA/maxresdefault.webp", "preference": 0, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/XXfKj3_NmHA/maxresdefault.jpg", "description": "Jeste li se ikada paralizirali od straha pitajući se: \"Što ako donesem pogrešnu odluku i zauvijek promašim Božju volju za svoj život?\" \n\nVećina nas odrasla je s idejom da je Božja volja poput tajnog labirinta. Vjerujemo da Bog ima samo jedan specifičan plan za našu karijeru, brak i budućnost, a naš je zadatak da ga \"otkrijemo\". Ako pogriješimo, osuđeni smo na \"plan B\". No, je li to doista ono što Biblija uči?\n\n\nU ovom predavanju razbijamo tjeskobu oko budućnosti i otkrivamo zapanjujuću slobodu koju nam Bog zapravo daje. Kroz osobno svjedočanstvo, analizu biblijskih tekstova (Jakovljeva poslanica, Govor na gori) i promišljanje o preprekama modernog doba, otkrivamo zašto se Božja volja mnogo više tiče toga tko postajemo danas, nego gdje ćemo biti sutra.", "channel_id": "UCqthf51zZqV4pui35VADN4w", "channel_url": "https://www.youtube.com/channel/UCqthf51zZqV4pui35VADN4w", "duration": 2804, "view_count": 70, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=XXfKj3_NmHA", "categories": ["Music"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 3, "like_count": 16, "channel": "Molitvena zajednica Eho", "channel_follower_count": 12500, "uploader": "Molitvena zajednica Eho", "uploader_id": "@ehoprojekt", "uploader_url": "https://www.youtube.com/@ehoprojekt", "upload_date": "20260218", "timestamp": 1771404670, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "XXfKj3_NmHA", "fulltitle": "Marko Matijašević - Kako otkriti Božju volju?", "duration_string": "46:44", "is_live": false, "was_live": false, "epoch": 1771413868, "asr": 22050, "filesize": 90140651, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 30, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 257.177, "filesize_approx": 90140377, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr4---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=1771435468&ei=bKGVaaupCLCIvdIPhu6c2A0&ip=89.201.137.96&id=o-AE7n3oxT_nTfq4v-MJoZ6xwvrQ_LAcZoAMIJ-Fa1mxA_&itag=18&source=youtube&requiressl=yes&xpc=EgVo2aDSNQ%3D%3D&cps=409&met=1771413868%2C&mh=3z&mm=31%2C29&mn=sn-v2uph5-15bl%2Csn-4g5lznek&ms=au%2Crdu&mv=m&mvi=4&pl=18&rms=au%2Cau&initcwndbps=1585000&b