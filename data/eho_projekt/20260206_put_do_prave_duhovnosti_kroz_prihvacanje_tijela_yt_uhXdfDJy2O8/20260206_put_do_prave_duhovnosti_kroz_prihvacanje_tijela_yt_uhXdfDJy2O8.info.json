i vlastitim emocijama. Govori o putu utjelovljenja vjere, o tome kako je slika Boga Oca prestala biti teorija i postala iskustvo koje je pokrenulo duboku životnu promjenu.\nOtvoreno govori i o tome kako su stres i zanemarivanje sebe bili vidljivi kroz nakupljene kilograme te kako je, nakon šest godina bezuspješnih pokušaja, započeo proces vraćanja sebe, sebi.\n\nAko imaš osjećaj da se već dugo boriš s nekim područjem života, da si zapela i da ti se nešto čini nemogućim , a želiš zaokret s Bogom koji čini sve novo, ova epizoda je za tebe.\nGledaj, slušaj i dopusti da te ova priča dotakne tamo gdje najviše treba.", "channel_id": "UCqthf51zZqV4pui35VADN4w", "channel_url": "https://www.youtube.com/channel/UCqthf51zZqV4pui35VADN4w", "duration": 2802, "view_count": 1806, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=uhXdfDJy2O8", "categories": ["Music"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 7, "like_count": 88, "channel": "Molitvena zajednica Eho", "channel_follower_count": 12500, "uploader": "Molitvena zajednica Eho", "uploader_id": "@ehoprojekt", "uploader_url": "https://www.youtube.com/@ehoprojekt", "upload_date": "20260206", "timestamp": 1770405113, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "uhXdfDJy2O8", "fulltitle": "⁠Put do prave duhovnosti kroz prihvaćanje tijela", "duration_string": "46:42", "is_live": false, "was_live": false, "epoch": 1771413890, "asr": 22050, "filesize": 91786484, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 30, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 262.073, "filesize_approx": 91786449, "width": 640, "language_pref