i.ytimg.com/vi_webp/DlRUsv4_6GI/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/DlRUsv4_6GI/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "40", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/DlRUsv4_6GI/maxresdefault.webp", "preference": 0, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/DlRUsv4_6GI/maxresdefault.jpg", "description": "U ovoj epizodi razgovaramo s Ricardom Hržicom – ekonomisticom, suprugom glazbenika i mamom dvojice dječaka.\n\nPričale smo o braku, životu uz umjetnika, izazovima i radostima majčinstva, ali i o tome koliko je važno pronaći sebe u svemu tome. Dotaknule smo se i tema poput vremena za sebe, osjećaja kada život nije uvijek po “planu” i kako se nositi s očekivanjima – vlastitim i tuđim.\n\nRazgovarale smo o:\n- životu i braku s glazbenikom \n- početku ljubavne priče Ricarde i Alana\n- majčinstvu i kako ostati mirna u kaosu svakodnevice\n- tajnama unutarnje stabilnosti i snage\n\nSve se, na kraju, svodi na ljubav, zajedništvo i učenje – kako rasti zajedno i kako u svemu čuvati ono što je najvažnije.\n\nPoslušaj, podijeli s nekim kome bi ovo moglo biti ohrabrenje, ostavi komentar i podsjeti se: savršenstvo nije cilj, bliskost jest.\n\nPOGLAVLJA:\n\nIntro - 00:32\nPredstavi sama sebe - 00:32\nRicardina poslovna priča - 01:23\nŽivot s glazbenikom - 10:10\nKako ste se ti i Alan upoznali? - 16:30\nKako vam je bilo kada ste krenuli skupa u vezu? - 21:16\nImaš li katkad osvrte na njegov prijašnji život? - 23:13\nKako je biti mama dvojice dječaka? - 24:58\nTajna tvoje staloženosti - 28:54\nVrijeme za mamu - 31:30", "channel_id": "UCqthf51zZqV4pui35VADN4w", "channel_url": "https://www.youtube.com/channel/UCqthf51zZqV4pui35VADN4w", "duration": 2501, "view_count": 14615, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=DlRUsv4_6GI", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_form