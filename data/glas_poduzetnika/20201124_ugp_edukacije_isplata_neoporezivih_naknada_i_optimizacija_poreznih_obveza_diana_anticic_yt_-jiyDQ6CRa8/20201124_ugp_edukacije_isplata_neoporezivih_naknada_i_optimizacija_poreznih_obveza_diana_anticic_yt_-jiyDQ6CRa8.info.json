ite kako izgledaju edukacije, što se da naučiti i zašto se isplati biti ponosni član UGP-a!\n\nDiana Antičić educirala je UGP članove o isplati neoporezivih naknada i optimizaciji poreznih obveza pa svakako poslušajte savjete jer možete biti od značajne koristi za vaše poslovanje.\n\nSve edukacije prikazujemo uživo u našoj Facebook grupi za članove:  https://www.facebook.com/groups/ugpedukacija. Sve dosadašnje edukacije su dostupne u grupi i dalje!", "channel_id": "UCK48gv8BTJOiH1QDPfa5eLQ", "channel_url": "https://www.youtube.com/channel/UCK48gv8BTJOiH1QDPfa5eLQ", "duration": 2228, "view_count": 159, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=-jiyDQ6CRa8", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 3, "channel": "Glas Poduzetnika", "channel_follower_count": 378, "uploader": "Glas Poduzetnika", "uploader_id": "@glaspoduzetnika8972", "uploader_url": "https://www.youtube.com/@glaspoduzetnika8972", "upload_date": "20201124", "timestamp": 1606222268, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "-jiyDQ6CRa8", "fulltitle": "[UGP EDUKACIJE] Isplata neoporezivih naknada i optimizacija poreznih obveza - Diana Antičić", "duration_string": "37:08", "is_live": false, "was_live": false, "epoch": 1771427657, "asr": 44100, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 30, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 343.798, "filesize_approx": 95764718, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr1---sn-v2uph5-15bl.googlevideo.com/vide