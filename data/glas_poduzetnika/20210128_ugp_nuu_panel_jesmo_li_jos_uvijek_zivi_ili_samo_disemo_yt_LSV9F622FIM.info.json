u gosti panela: Hrvoje Bujas (UGP), Vuk Vuković (UGP), Jelena Tabak (NUU) i Vedran Jakominić (NUU). Raspravu je moderirala Maruša Stamać, glavna koordinatorica UGP-a.", "channel_id": "UCK48gv8BTJOiH1QDPfa5eLQ", "channel_url": "https://www.youtube.com/channel/UCK48gv8BTJOiH1QDPfa5eLQ", "duration": 3679, "view_count": 107, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=LSV9F622FIM", "categories": ["People & Blogs"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 3, "channel": "Glas Poduzetnika", "channel_follower_count": 378, "uploader": "Glas Poduzetnika", "uploader_id": "@glaspoduzetnika8972", "uploader_url": "https://www.youtube.com/@glaspoduzetnika8972", "upload_date": "20210128", "timestamp": 1611861697, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "LSV9F622FIM", "fulltitle": "UGP & NUU Panel - JESMO LI JOŠ UVIJEK ŽIVI... ili samo dišemo?", "duration_string": "1:01:19", "is_live": false, "was_live": false, "epoch": 1771419440, "asr": 44100, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 30, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 400.813, "filesize_approx": 184314208, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr2---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=1771441040&ei=MLeVadDnA5yo6dsPkda02Q0&ip=89.201.137.96&id=o-AGwUj6dyneEaN_b0QQHaNHnoS5f6mfWGgVYS-wRQo0Z7&itag=18&source=youtube&requiressl=yes&xpc=EgVo2aDSNQ%3D%3D&cps=311&met=1771419440%2C&mh=9s&mm=31%2C29&mn=sn-v2uph5-15bl%2Csn-4g5lznez&ms=au%2Crdu&mv=m&mvi=2&pl=18&rms=au%2Cau&initcwndbps=146