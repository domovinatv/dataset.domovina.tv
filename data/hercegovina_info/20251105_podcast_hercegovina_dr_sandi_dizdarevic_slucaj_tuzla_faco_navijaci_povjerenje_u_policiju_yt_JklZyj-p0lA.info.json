idth": 336, "preference": -7, "id": "34", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi_webp/JklZyj-p0lA/hqdefault.webp", "height": 360, "width": 480, "preference": -6, "id": "35", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi/JklZyj-p0lA/sddefault.jpg", "preference": -5, "id": "36"}, {"url": "https://i.ytimg.com/vi_webp/JklZyj-p0lA/sddefault.webp", "height": 480, "width": 640, "preference": -4, "id": "37", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi/JklZyj-p0lA/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/JklZyj-p0lA/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/JklZyj-p0lA/maxresdefault.jpg", "height": 720, "width": 1280, "preference": -1, "id": "40", "resolution": "1280x720"}, {"url": "https://i.ytimg.com/vi_webp/JklZyj-p0lA/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "41", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/JklZyj-p0lA/maxresdefault.webp", "description": "U novoj epizodi podcasta Hercegovina govorimo o jednom od najmučnijih slučajeva u Bosni i Hercegovini - podvođenju maloljetnica u Tuzli, u koje su umiješani policijski službenici, profesori i lokalni moćnici.\n\nGost je dr. Sandi Dizdarević, stručnjak za kriminalistiku i sigurnosne studije, koji razotkriva kako su institucije postale dio mreže zla, od korupcije u policiji do zataškavanja slučajeva trgovine ljudima.\n\nPoglavlja:\n00:00 Uvod\n01:10 Tuzla i Sarajevo: što se doista događa\n03:40 Trajanje istraga i profesionalni standardi\n05:54 Mediji, identitet maloljetnica i etika izvještavanja\n06:50 Povjerenje u policiju i provjere imovine\n09:30 Sigurnosne provjere, „crvene zastavice“\n10:25 Black Tie i Sky: što je razotkriveno\n16:24 Depolitizacija i model upravljanja policijom\n16:49 Tetovaže i standardi za posebne postrojbe\n19:05 Navijačke grupe, „omerta“ i kazneni progon\n21:09 Građansko zadržavanje i obveza prijave\n30:22 Slučaj Amir Pašić Faćo i online nasilje\n34:20 Zaključak: reforma i odgovornost društva\n\nGovorimo o zaštiti žena i djece od seksualne eksploatacije, o hrabrim pojedincima koji progovaraju i o cijeni koju plaćaju kad sustav odluči stati na stranu zla.\n\n🎙️ Voditelj: Nikola Bačić\n🧠 Gost: dr. Sandi Dizdarević\n📍 Podcast Hercegovina\n\n👉 Pretplatite se, komentirajte i podijelite epizodu.\n\n#Tuzla #Policija #TrgovinaLjudima #SandiDizdarević #Sky #BlackTie #Panteri #PodcastHercegovina #Korupcija #BiH #Faćo #Navijači #SeksualnaEksploatacija #hercegovinainfo \n\n\nhttps://www.hercegovina.info/\n\n\nhttps://www.facebook.com/Hercegovina.Info1\nhttps://twitter.com/hercegovinainfo\nhttps://www.instagram.com/hercegovina.info/", "channel_id": "UCHqOpHIEveT_cRSPElzyOEw", "channel_url": "https://www.youtube.com/channel/UCHqOpHIEveT_cRSPElzyOEw", "duration": 2148, "view_count": 11739, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=JklZyj-p0lA", "categories": ["Autos & Vehicles"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "chapters": [{"start_time": 0.0, "title": "Uvod", "end_time": 70.0}, {"start_time": 70.0, "title": "Tuzla i Sarajevo: što se doista događa", "end_time": 220.0}, {"start_time": 220.0, "title": "Trajanje istraga i profesionalni standardi", "end_time": 354.0}, {"start_time": 354.0, "title": "Mediji, identitet maloljetnica i etika izvještavanja", "end_time": 410.0}, {"start_time": 410.0, "title": "Povjerenje u policiju i provjere imovine", "end_time": 570.0}, {"start_time": 570.0, "title": "Sigurnosne provjere, „crvene zastavice“", "end_time": 625.0}, {"start_time": 625.0, "title": "Black Tie i Sky: što je razotkriveno", "end_time": 984.0}, {"start_time": 984.0, "title": "Depolitizacija i model upravljanja policijom", "end_time": 1009.0}, {"start_time": 100