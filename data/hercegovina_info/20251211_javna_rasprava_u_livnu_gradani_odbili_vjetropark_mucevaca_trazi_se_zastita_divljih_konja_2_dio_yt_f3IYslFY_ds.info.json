": "https://i.ytimg.com/vi/f3IYslFY_ds/hqdefault.jpg?sqp=-oaymwEcCNACELwBSFXyq4qpAw4IARUAAIhCGAFwAcABBg==&rs=AOn4CLAPlAhLn6zKDWnDlotT9I7aAyRb3w", "height": 188, "width": 336, "preference": -7, "id": "34", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi_webp/f3IYslFY_ds/hqdefault.webp", "height": 360, "width": 480, "preference": -6, "id": "35", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi/f3IYslFY_ds/sddefault.jpg", "preference": -5, "id": "36"}, {"url": "https://i.ytimg.com/vi_webp/f3IYslFY_ds/sddefault.webp", "height": 480, "width": 640, "preference": -4, "id": "37", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi/f3IYslFY_ds/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/f3IYslFY_ds/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/f3IYslFY_ds/maxresdefault.jpg", "height": 720, "width": 1280, "preference": -1, "id": "40", "resolution": "1280x720"}, {"url": "https://i.ytimg.com/vi_webp/f3IYslFY_ds/maxresdefault.webp", "height": 1080, "width": 1920, "preference": 0, "id": "41", "resolution": "1920x1080"}], "thumbnail": "https://i.ytimg.com/vi_webp/f3IYslFY_ds/maxresdefault.webp", "description": "Cijela javna rasprava održana u Livnu povodom Studije utjecaja na okoliš za planirani vjetropark Mućevača, koju su građani jednoglasno odbili.\n\nStanovnici su poručili predstavnicima EA Energy d.o.o. i Federalnog ministarstva okoliša da na visoravan Kruzi dođu kao turisti, a ne kao koncesionari koji bi izgradnjom vjetroturbina narušili prirodni ambijent, ugrozili vodne resurse i potkopali razvoj turizma.\n\nNa raspravi su otvorena ključna pitanja:\n• rizik za izvor pitke vode Duman\n• utjecaj na divlje konje i visoravan Kruge\n• vizualno i zvučno narušavanje prostora\n• manjkava i kontradiktorna studija koju su građani proglasili “copy–paste dokumentom”\n• nepostojanje predstavnika Vlade HBŽ, koja je dodijelila koncesiju\n• kulturna i arheološka baština, turističke posljedice i gospodarski aspekt\n\nGrad Livno je već ranije uputio opsežne primjedbe na projekt i zatražio da se zahtjev za okolišnu dozvolu ne odobri. Rasprava je pokazala da lokalna zajednica odlučno odbacuje izgradnju vjetroparka Mućevača.\n\nCijeli tekst i fotogaleriju potpisuje portal Hercegovina.info.\n\n👉 Pretplatite se, komentirajte i podijelite.\n\n➡️ Cijeli članak na: https://www.hercegovina.info/\n\n🔗 Pratite nas:\n\nFacebook: https://www.facebook.com/Hercegovina.Info1\n\nInstagram: https://www.instagram.com/hercegovina.info/\n\nX/Twitter: https://twitter.com/hercegovinainfo", "channel_id": "UCHqOpHIEveT_cRSPElzyOEw", "channel_url": "https://www.youtube.com/channel/UCHqOpHIEveT_cRSPElzyOEw", "duration": 3338, "view_count": 239, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=f3IYslFY_ds", "categories": ["News & Politics"], "tags": [], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 1, "channel": "Hercegovina.info", "channel_follower_count": 3460, "uploader": "Hercegovina.info", "uploader_id": "@HercegovinaInfo2", "uploader_url": "https://www.youtube.com/@HercegovinaInfo2", "upload_date": "20251211", "timestamp": 1765441837, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "f3IYslFY_ds", "fulltitle": "Javna rasprava u Livnu: Građani odbili vjetropark Mućevača, traži se zaštita divljih konja 2. dio", "duration_string": "55:38", "is_live": false, "was_live": false, "epoch": 1771419516, "asr": 44100, "filesize": 108732296, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 25, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 260.621, "filesize_approx": 108732253, "width": 640, "language_preference":