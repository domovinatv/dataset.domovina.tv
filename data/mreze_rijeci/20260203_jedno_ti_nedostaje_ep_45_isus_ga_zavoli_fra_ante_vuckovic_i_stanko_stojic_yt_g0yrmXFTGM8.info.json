": 196, "preference": -7, "id": "31", "resolution": "196x110"}, {"url": "https://i.ytimg.com/vi/g0yrmXFTGM8/hqdefault.jpg?sqp=-oaymwEcCPYBEIoBSFXyq4qpAw4IARUAAIhCGAFwAcABBg==&rs=AOn4CLDEPOB4knWy3VhJNb0SWqaaNGB-5w", "height": 138, "width": 246, "preference": -7, "id": "32", "resolution": "246x138"}, {"url": "https://i.ytimg.com/vi/g0yrmXFTGM8/hqdefault.jpg?sqp=-oaymwEcCNACELwBSFXyq4qpAw4IARUAAIhCGAFwAcABBg==&rs=AOn4CLDwAwU3RER_fYnDj3RI4krxOSvYYQ", "height": 188, "width": 336, "preference": -7, "id": "33", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/g0yrmXFTGM8/hqdefault.jpg", "height": 360, "width": 480, "preference": -7, "id": "34", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/g0yrmXFTGM8/hqdefault.webp", "preference": -6, "id": "35"}, {"url": "https://i.ytimg.com/vi/g0yrmXFTGM8/sddefault.jpg", "height": 480, "width": 640, "preference": -5, "id": "36", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi_webp/g0yrmXFTGM8/sddefault.webp", "preference": -4, "id": "37"}, {"url": "https://i.ytimg.com/vi/g0yrmXFTGM8/hq720.jpg", "preference": -3, "id": "38"}, {"url": "https://i.ytimg.com/vi_webp/g0yrmXFTGM8/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/g0yrmXFTGM8/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "40", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/g0yrmXFTGM8/maxresdefault.webp", "preference": 0, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/g0yrmXFTGM8/maxresdefault.jpg", "description": "Urednik i voditelj: Stanko Stojić\nSugovornik: fra Ante Vučković\n\nEPIZODA 45\n\nČitanje: \nOpasnost bogatstva (Mk 10, 17–22)\n\nI dok je izlazio na put, dotrči netko, klekne preda nj pa ga upita: »Učitelju dobri, što mi je činiti da baštinim život vječni?« Isus mu reče: »Što me zoveš dobrim? Nitko nije dobar doli Bog jedini! Zapovijedi znadeš: Ne ubij!\nNe čini preljuba!\nNe ukradi!\nNe svjedoči lažno!\nNe otmi!\nPoštuj oca svoga i majku!«\n\nOn mu odgovori: »Učitelju, sve sam to čuvao od svoje mladosti.« Isus ga nato pogleda, zavoli ga i rekne mu: »Jedno ti nedostaje! Idi i što imaš, prodaj i podaj siromasima pa ćeš imati blago na nebu. A onda dođi i idi za mnom.« On se na tu riječ smrkne i ode žalostan jer imaše velik imetak.\n\nOPIS 45. EMISIJE: \n\nBogati mladi čovjek klekne pred Isusa i zamoli ga da mu kaže što mu je činiti da bi stekao vječni život. Isus ga upućuje na dobro poznate zapovijedi. Nakon što mladić kaže da je vjerno izvršavao sve što piše u zakonu Isus od njega traži da ide korak dalje, da se svega  odrekne i krene za njim. Na te riječi mladić se smrkne i ode od Isusa žalostan, zarobljen svojim bogatstvom.\n\nNaša je vjernička dužnost zapitati se što je to u našem životu i u našim konkretnim životnim okolnostima što nam priječi potpuno predanje Kristu. Svatko od nas živi u specifičnom okruženju i određenom životnom kontekstu i može se dogoditi da postanemo slijepi za prepreke koje nam stoje pred očima i priječe put do Boga. Možda je vrijeme da se zapitamo - što nam nedostaje?\n\nKratak opis emisije:\n\nMarkovo evanđelje je jedan od fundamentalnih tekstova naše vjere, kulture i povijesti. Fra Ante Vučković, duhovnik i intelektualac i Stanko Stojić, vjeroučitelj i novinar u serijalu \"Jedno ti nedostaje\" čitaju Markovo evanđelje redak po redak i pokušavaju ga analizirati, interpretirati i protumačiti iz perspektive suvremenog čovjeka. Pritom se bave pitanjima: Kako nam ovaj sveti tekst pomaže urediti život i produbiti odnos s Bogom i ljudima? Što nam evanđelje otkriva o prirodi čovjeka i svijeta, dobra i zla, slobode i ljudske savjesti? Ima li evanđelist Marko odgovore na naša životna i svakodnevna pitanja koja podrazumijevaju svijest o osobnoj nedostatnosti, grešnosti i potrebi za ljubavlju i mirom. Fra Ante i Stanko razgovaraju otvoreno, neposredno, bez pomno zacrtanog scenarija i sa puno referenci na fenomene iz suvremenog društva, povijesti filozofije i humanistike te na stanje u Crkvi i svijetu. \n\nOznake: #jednotinedostaje #markovoevandjelje #biblija #antevuckovic #stankostojic #podcast\n\nPRODUKCIJSKI TIM MREŽE RIJEČI \nDanijela Musulin & Ivana Raspudić \nGlavna urednica: prof. dr. sc. Jadranka Garmaz \n\n©Mreže Riječi\n\nKONTAKT:\ninfo@mrezerijeci.com\nWeb: https://mrezerijeci.com/\nFacebook: https://www.facebook.com/mrezerijeci\nInstagram: https://www.instagram.com/mrezerijeci/", "channel_id": "UCX7jtR9MufouIC20G7AAVOg", "channel_url": "https://www.youtube.com/channel/UCX7jtR9MufouIC20G7AAVOg", "duration": 1542, "view_count": 5024, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=g0yrmXFTGM8", "categories": ["Education"], "tags": ["vjera", "bog", "evanđelje"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 9, "like_count": 162, "channel": "Mreže Riječi", "channel_follower_count": 4910, "uploader": "Mreže Riječi", "uploader_id": "@mrezerijeci", "uploader_url": "https://www.youtube.com/@mrezerijeci", "upload_date": "20260203", "timestamp": 1770137011, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "g0yrmXFTGM8", "fulltitle": "Jedno ti nedostaje: EP 45 - Isus ga zavoli - fra Ante Vučković i Stanko Stojić", "duration_string": "25:42", "is_live": false, "was_live": false, "epoch": 1771420147, "asr": 44100, "filesize": 69817039, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 25, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 362.184, "filesize_approx": 69816851, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr3---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=17714417