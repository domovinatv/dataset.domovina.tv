i_webp/evEkmZMGB40/hq720.webp", "preference": -2, "id": "39"}, {"url": "https://i.ytimg.com/vi/evEkmZMGB40/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "40", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/evEkmZMGB40/maxresdefault.webp", "preference": 0, "id": "41"}], "thumbnail": "https://i.ytimg.com/vi/evEkmZMGB40/maxresdefault.jpg", "description": "Urednica i voditeljica: dr. sc. Gina Šparada\n\nU drugoj epizodi pogledajte:\nDr. sc. Gina Šparada nastavlja stručno i razumljivo voditi gledatelje kroz područje mentalnog zdravlja, s posebnim naglaskom na ekscentrične poremećaje ličnosti. Predstavila je sastavne dijelove ličnosti te poremećaje ličnosti koje karakterizira neobično, čudno i ekscentrično ponašanje, kao i izražene poteškoće u socijalnim odnosima. Osobe koje pokazuju karakteristike ove grupe poremećaja često djeluju povučeno, sumnjičavo ili emocionalno distancirano.\nKroz stručnu analizu i primjere iz prakse, dr. sc. Gina Šparada približava gledateljima razumijevanje ovih poremećaja te naglašava važnost prepoznavanja i adekvatne podrške.\n\nKratak opis emisije:\nU vremenu kada su emocije često potisnute, pogrešno shvaćene ili neregulirane, ova emisija otvara prostor za razumijevanje, rast i iscjeljenje.\nKroz spoj psiholoških spoznaja o sazrijevanju, emocijama i poremećajima osobnosti koji mogu uslijediti uslijed krivog razvoja, emisija vodi gledatelje na put prema dubljem upoznavanju vlastitog unutarnjeg svijeta – kako bismo naučili upravljati emocijama, a ne njima biti vođeni. Emocionalna i socijalna inteligencija nisu samo „meke vještine“, nego temelj zrelih odnosa, empatije i autentične ljubavi koja gradi zajedništvo.\n\nOznake: #skolaemocionalnezrelosti #emocije #traume #ličnost\n\nPRODUKCIJSKI TIM MREŽE RIJEČI \nDanijela Musulin & Ivana Raspudić \nGlavna urednica: prof. dr. sc. Jadranka Garmaz \n\n©Mreže Riječi\n\nKONTAKT:\ninfo@mrezerijeci.com\nWeb: https://mrezerijeci.com/\nFacebook: https://www.facebook.com/mrezerijeci\nInstagram: https://www.instagram.com/mrezerijeci/", "channel_id": "UCX7jtR9MufouIC20G7AAVOg", "channel_url": "https://www.youtube.com/channel/UCX7jtR9MufouIC20G7AAVOg", "duration": 1160, "view_count": 444, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=evEkmZMGB40", "categories": ["Education"], "tags": ["vjera", "bog", "evanđelje"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 1, "like_count": 22, "channel": "Mreže Riječi", "channel_follower_count": 4910, "uploader": "Mreže Riječi", "uploader_id": "@mrezerijeci", "uploader_url": "https://www.youtube.com/@mrezerijeci", "upload_date": "20251222", "timestamp": 1766395175, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "evEkmZMGB40", "fulltitle": "Škola emocionalne zrelosti: EP 02 - Ekscentrični poremećaji ličnosti - dr. sc. Gina Šparada", "duration_string": "19:20", "is_live": false, "was_live": false, "epoch": 1771428244, "asr": 22050, "filesize": 36134754, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 25, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 249.11, "filesize_approx": 36134651, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr2---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=1771449844&ei=lNmVaY7DF9jLi9oPif6lsAY&ip=89.201.137.96&id=o-AEVzmyJL29zVe5dLoS3_GbgRELqwd8EuaYtYahHuvv4t&itag=18&source=youtube&requiressl=yes&xpc=EgVo2aDSNQ%3D%3D&cps=384&met=1771428244%2C&mh=5o&mm=31%2C29&mn=sn-v2uph5-15bl%2Csn-4g5lzne6&ms=au%2Crdu&mv=m&mvi=2&pl=18&rms=au%2Cau&initcwndbps=1111250&bui=AW-iu_poxqBlBA5-gCV8