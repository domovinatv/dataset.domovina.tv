reference": -6, "id": "39"}, {"url": "https://i.ytimg.com/vi/n0byZm32gV4/sddefault.jpg", "preference": -5, "id": "40"}, {"url": "https://i.ytimg.com/vi_webp/n0byZm32gV4/sddefault.webp", "preference": -4, "id": "41"}, {"url": "https://i.ytimg.com/vi/n0byZm32gV4/hq720.jpg", "preference": -3, "id": "42"}, {"url": "https://i.ytimg.com/vi_webp/n0byZm32gV4/hq720.webp", "preference": -2, "id": "43"}, {"url": "https://i.ytimg.com/vi/n0byZm32gV4/maxresdefault.jpg", "height": 1080, "width": 1920, "preference": -1, "id": "44", "resolution": "1920x1080"}, {"url": "https://i.ytimg.com/vi_webp/n0byZm32gV4/maxresdefault.webp", "preference": 0, "id": "45"}], "thumbnail": "https://i.ytimg.com/vi/n0byZm32gV4/maxresdefault.jpg", "description": "Urednica i voditeljica: dr. sc. Gina Šparada\n\nU četvrtoj epizodi pogledajte:\nU novoj epizodi emisije Škola emotivne zrelosti nastavljamo s istraživanjem poremećaja ličnosti i predstavljamo treću skupinu poremećaja ličnosti.\nOvu skupinu obilježavaju izražena tjeskoba, nesigurnost i stalna potreba za sigurnošću i potvrdom. Osobe s ovim obrascima često doživljavaju sebe kao nedovoljno sposobne ili manje vrijedne, boje se kritike, odbacivanja ili gubitka podrške te razvijaju snažnu potrebu za kontrolom kako bi smanjile unutarnju napetost.\nPridružite nam se u novoj epizodi i otkrijte kako razumijevanje ovih dinamika može biti prvi korak prema dubljoj emotivnoj zrelosti.\n\nKratak opis emisije:\nU vremenu kada su emocije često potisnute, pogrešno shvaćene ili neregulirane, ova emisija otvara prostor za razumijevanje, rast i iscjeljenje.\nKroz spoj psiholoških spoznaja o sazrijevanju, emocijama i poremećajima osobnosti koji mogu uslijediti uslijed krivog razvoja, emisija vodi gledatelje na put prema dubljem upoznavanju vlastitog unutarnjeg svijeta – kako bismo naučili upravljati emocijama, a ne njima biti vođeni. Emocionalna i socijalna inteligencija nisu samo „meke vještine“, nego temelj zrelih odnosa, empatije i autentične ljubavi koja gradi zajedništvo.\n\nOznake: #skolaemocionalnezrelosti #emocije #traume #ličnost\n\nPRODUKCIJSKI TIM MREŽE RIJEČI \nDanijela Musulin & Ivana Raspudić Jurin\nGlavna urednica: prof. dr. sc. Jadranka Garmaz \n\n©Mreže Riječi\n\nKONTAKT:\ninfo@mrezerijeci.com\nWeb: https://mrezerijeci.com/\nFacebook: https://www.facebook.com/mrezerijeci\nInstagram: https://www.instagram.com/mrezerijeci/", "channel_id": "UCX7jtR9MufouIC20G7AAVOg", "channel_url": "https://www.youtube.com/channel/UCX7jtR9MufouIC20G7AAVOg", "duration": 1021, "view_count": 351, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=n0byZm32gV4", "categories": ["Education"], "tags": ["vjera", "bog", "evanđelje"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "like_count": 20, "channel": "Mreže Riječi", "channel_follower_count": 5000, "uploader": "Mreže Riječi", "uploader_id": "@mrezerijeci", "uploader_url": "https://www.youtube.com/@mrezerijeci", "upload_date": "20260223", "timestamp": 1771851029, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "n0byZm32gV4", "fulltitle": "Škola emocionalne zrelosti: EP 04 - Anksiozna skupina poremećaja ličnosti - dr. sc. Gina Šparada", "duration_string": "17:01", "is_live": false, "was_live": false, "epoch": 1773756627, "asr": 22050, "filesize": 34018640, "format_id": "18", "format_note": "360p", "source_preference": -1, "fps": 25, "audio_channels": 2, "height": 360, "quality": 6.0, "has_drm": false, "tbr": 266.483, "filesize_approx": 34018553, "width": 640, "language_preference": -1, "ext": "mp4", "vcodec": "avc1.42001E", "acodec": "mp4a.40.2", "dynamic_range": "SDR", "url": "https://rr2---sn-v2uph5-15bl.googlevideo.com/videoplayback?expire=1773778226&ei=0mC5adf9C92np-oP