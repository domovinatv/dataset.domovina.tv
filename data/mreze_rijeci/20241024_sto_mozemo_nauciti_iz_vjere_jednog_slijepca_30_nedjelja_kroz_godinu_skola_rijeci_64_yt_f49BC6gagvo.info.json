], "thumbnail": "https://i.ytimg.com/vi/f49BC6gagvo/maxresdefault.jpg", "description": "Škola Riječi je projekt u suradnji s fra Domagojem Runjom – izvanrednim profesorom biblijske skupine predmeta na Katoličkom bogoslovnom fakultetu u Splitu. Svaki četvrtak donijeti ćemo promišljanje o Božjoj Riječi za nadolazeću nedjelju.\n\nNeka ovaj video – sjeme Božje Riječi za tridesetu nedjelju kroz godinu – pronađe plodno tlo u vašim srcima.\n-------------------------------------\nSnimano u crkvi sv. Franje (franjevački klerikat Split)\n\nPRODUKCIJSKI TIM\nPredavač: prof. dr. sc. fra Domagoj Runje\nUrednik: prof. dr. sc. Jadranka Garmaz\nIzvršni urednik: dr. sc. Nenad Palac\nSnimanje: Ivana Raspudić i Danijela Musulin \nMontaža: Danijela Musulin\n\n©Mreže Riječi\n\nKONTAKT:\ninfo@mrezerijeci.com\nWeb: https://mrezerijeci.com/\nFacebook: https://www.facebook.com/mrezerijeci\nInstagram: https://www.instagram.com/mrezerijeci/", "channel_id": "UCX7jtR9MufouIC20G7AAVOg", "channel_url": "https://www.youtube.com/channel/UCX7jtR9MufouIC20G7AAVOg", "duration": 910, "view_count": 1118, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=f49BC6gagvo", "categories": ["Education"], "tags": ["vjera", "bog", "evanđelje"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 2, "like_count": 58, "channel": "Mreže Riječi", "channel_follower_count": 4910, "uploader": "Mreže Riječi", "uploader_id": "@mrezerijeci", "uploader_url": "https://www.youtube.com/@mrezerijeci", "upload_date": "20241024", "timestamp": 1729789930, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "f49BC6gagvo", "fulltitle": "„Što možemo naučiti iz vjere jednog slijepca?“– 30. nedjelja kroz godinu [Šk